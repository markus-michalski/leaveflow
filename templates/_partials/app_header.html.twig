{# Global app header — logo + nav + admin menu + bell + user menu.
   Rendered by base.html.twig on every authenticated page. Login,
   password-reset, and error templates suppress it via empty
   {% block app_header %}{% endblock %} overrides.

   Mobile (<md viewport): all nav items collapse behind a Flowbite
   data-collapse-toggle hamburger; the user-menu button stays
   visible because the dropdown contains the logout. #}
<header class="border-b border-gray-200 bg-white">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-3 sm:px-6">
        <a href="{{ path('app_dashboard') }}"
           class="inline-flex items-center gap-2 text-base font-semibold text-gray-900 hover:text-blue-700"
           data-testid="app-header-home">
            <span aria-hidden="true">🏖️</span>
            <span>{{ 'app.name'|trans }}</span>
        </a>

        <button type="button"
                data-collapse-toggle="app-header-nav"
                aria-controls="app-header-nav"
                aria-expanded="false"
                aria-label="{{ 'nav.menu_label'|trans }}"
                class="inline-flex items-center justify-center rounded-md p-2 text-gray-600 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 md:hidden">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>

        <div id="app-header-nav"
             class="hidden w-full md:flex md:w-auto md:items-center md:gap-3"
             data-testid="app-header-nav">
            <nav class="flex flex-col gap-2 py-2 md:flex-row md:items-center md:gap-3 md:py-0"
                 aria-label="{{ 'nav.primary'|trans }}">
                {% if is_granted('ROLE_ADMIN') %}
                    <div class="relative">
                        <button type="button"
                                data-dropdown-toggle="admin-menu"
                                aria-haspopup="menu"
                                aria-expanded="false"
                                class="inline-flex w-full items-center justify-between gap-2 whitespace-nowrap rounded-md border border-blue-200 bg-blue-50 px-3 py-2 text-sm font-medium text-blue-700 hover:bg-blue-100 focus:outline-none focus:ring-2 focus:ring-blue-500 md:w-auto">
                            {{ 'nav.admin.menu'|trans }}
                            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                            </svg>
                        </button>
                        <div id="admin-menu"
                             class="z-10 hidden w-56 divide-y divide-gray-100 rounded-lg bg-white shadow-lg ring-1 ring-black/5">
                            <ul class="py-1 text-sm text-gray-700" role="menu" aria-orientation="vertical">
                                <li>
                                    <a href="{{ path('app_admin_user_index') }}" role="menuitem" class="block px-4 py-2 hover:bg-gray-100">{{ 'nav.admin.users'|trans }}</a>
                                </li>
                                <li>
                                    <a href="{{ path('app_admin_location_index') }}" role="menuitem" class="block px-4 py-2 hover:bg-gray-100">{{ 'nav.admin.locations'|trans }}</a>
                                </li>
                                <li>
                                    <a href="{{ path('app_admin_department_index') }}" role="menuitem" class="block px-4 py-2 hover:bg-gray-100">{{ 'nav.admin.departments'|trans }}</a>
                                </li>
                                <li>
                                    <a href="{{ path('app_admin_employee_index') }}" role="menuitem" class="block px-4 py-2 hover:bg-gray-100">{{ 'nav.admin.employees'|trans }}</a>
                                </li>
                                <li>
                                    <a href="{{ path('app_admin_holiday_index') }}" role="menuitem" class="block px-4 py-2 hover:bg-gray-100">{{ 'nav.admin.holidays'|trans }}</a>
                                </li>
                                <li>
                                    <a href="{{ path('app_admin_absence_type_index') }}" role="menuitem" class="block px-4 py-2 hover:bg-gray-100">{{ 'nav.admin.absence_types'|trans }}</a>
                                </li>
                                <li>
                                    <a href="{{ path('app_admin_entitlement_index') }}" role="menuitem" class="block px-4 py-2 hover:bg-gray-100">{{ 'nav.admin.entitlements'|trans }}</a>
                                </li>
                                <li>
                                    <a href="{{ path('app_admin_leave_request_index') }}" role="menuitem" class="block px-4 py-2 hover:bg-gray-100">{{ 'nav.admin.leave_requests'|trans }}</a>
                                </li>
                                <li>
                                    <a href="{{ path('app_admin_blackout_period_index') }}" role="menuitem" class="block px-4 py-2 hover:bg-gray-100">{{ 'nav.admin.blackout_periods'|trans }}</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                {% endif %}

                {% if app.user.hasEmployee %}
                    <a href="{{ path('app_my_leave_request_index') }}"
                       data-testid="nav-my-leave-requests"
                       class="inline-flex items-center gap-2 whitespace-nowrap rounded-md border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                        {{ 'nav.requests'|trans }}
                    </a>
                {% endif %}

                <a href="{{ path('app_team_calendar_index') }}"
                   data-testid="nav-team-calendar"
                   class="inline-flex items-center gap-2 whitespace-nowrap rounded-md border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                    {{ 'nav.team.calendar'|trans }}
                </a>

                {% if is_granted('ROLE_MANAGER') %}
                    <a href="{{ path('app_manager_approval_index') }}"
                       data-testid="nav-manager-approvals"
                       class="inline-flex items-center gap-2 whitespace-nowrap rounded-md border border-blue-200 bg-blue-50 px-3 py-2 text-sm font-medium text-blue-700 hover:bg-blue-100">
                        {{ 'nav.manager.approvals'|trans }}
                    </a>
                {% endif %}
            </nav>

            <div class="flex items-center gap-3 py-2 md:py-0">
                <turbo-frame id="notification-bell"
                             src="{{ path('app_my_notification_bell') }}"
                             data-controller="auto-refresh"
                             data-auto-refresh-interval-value="30000"
                             loading="lazy">
                    {# Skeleton while the frame loads — same shape as the loaded bell. #}
                    <a href="{{ path('app_my_notification_index') }}"
                       data-turbo-frame="_top"
                       class="inline-flex items-center justify-center rounded-full bg-white p-2 ring-1 ring-gray-200"
                       aria-label="{{ 'notifications.bell.aria_loading'|trans({}, 'notifications') }}">
                        <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                                  d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
                        </svg>
                    </a>
                </turbo-frame>

                <div class="relative">
                    {% set emailInitial = app.user.email|slice(0, 1)|upper %}
                    <button type="button"
                            data-dropdown-toggle="user-menu"
                            aria-haspopup="menu"
                            aria-expanded="false"
                            aria-label="{{ 'nav.user.menu_label'|trans }}"
                            class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-blue-600 text-sm font-semibold text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                        {{ emailInitial }}
                    </button>
                    <div id="user-menu"
                         class="z-10 hidden w-64 divide-y divide-gray-100 rounded-lg bg-white shadow-lg ring-1 ring-black/5">
                        <div class="px-4 py-3 text-sm">
                            <div class="font-medium text-gray-900">{{ app.user.email }}</div>
                            {% set role = app.user.roles|first %}
                            {% if role %}
                                <div class="text-xs text-gray-500">{{ role|replace({'ROLE_': ''})|lower|capitalize }}</div>
                            {% endif %}
                        </div>
                        <ul class="py-1 text-sm text-gray-700" role="menu" aria-orientation="vertical">
                            <li>
                                <a href="{{ path('app_profile') }}" role="menuitem" class="block px-4 py-2 hover:bg-gray-100">{{ 'nav.profile'|trans }}</a>
                            </li>
                        </ul>
                        <div class="py-1">
                            <form action="{{ path('app_logout') }}" method="post">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                <button type="submit" role="menuitem" class="block w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-100">{{ 'nav.logout'|trans }}</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>
