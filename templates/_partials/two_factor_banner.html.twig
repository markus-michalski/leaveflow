{# Site-wide 2FA reminder banner. Only renders when:
   - the user has no TOTP enabled, AND
   - their company has the 2FA requirement turned on.
   Once the grace deadline passes the EnforcementSubscriber redirects
   them to /profile/2fa/setup directly, so the banner stays soft. #}
{% if user.isTotpEnabled() is same as(false) and user.company.requiresTwoFactor() %}
    {% set deadline = user.company.twoFactorEnforcedFrom %}
    {% set enforced = user.company.isTwoFactorEnforced(date()) %}
    <div class="border-b {{ enforced ? 'border-red-200 bg-red-50 text-red-900' : 'border-yellow-200 bg-yellow-50 text-yellow-900' }}"
         data-testid="global-2fa-banner">
        <div class="mx-auto max-w-7xl px-4 py-3 text-sm sm:flex sm:items-center sm:justify-between">
            <div>
                <p class="font-semibold">
                    {{ enforced ? '2fa.banner.now_title'|trans : '2fa.banner.upcoming_title'|trans }}
                </p>
                <p class="mt-0.5 text-xs">
                    {% if enforced %}
                        {{ '2fa.banner.now_detail'|trans }}
                    {% else %}
                        {{ '2fa.banner.upcoming_detail'|trans({ '%date%': deadline|date('d.m.Y') }) }}
                    {% endif %}
                </p>
            </div>
            <a href="{{ path('app_profile_2fa_setup') }}"
               class="mt-2 inline-flex items-center whitespace-nowrap rounded-md border {{ enforced ? 'border-red-300 bg-white text-red-800 hover:bg-red-100' : 'border-yellow-300 bg-white text-yellow-900 hover:bg-yellow-100' }} px-3 py-1.5 text-xs font-medium sm:mt-0"
               data-testid="global-2fa-banner-cta">
                {{ '2fa.banner.cta'|trans }}
            </a>
        </div>
    </div>
{% endif %}
