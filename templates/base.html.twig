<!DOCTYPE html>
<html lang="{{ app.request.locale|default('de') }}" class="h-full bg-gray-50">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{{ 'app.name'|trans }}{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏖️</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
            <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
            <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
            <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="h-full text-gray-900 antialiased">
        {% block flashes %}
            {% if app.flashes|length > 0 %}
                <div class="fixed top-4 right-4 z-50 flex flex-col gap-2 max-w-sm">
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div data-controller="flash" data-flash-timeout-value="5000"
                                 class="flex items-start gap-3 rounded-lg px-4 py-3 shadow-lg transition duration-200 ease-out
                                    {{ label == 'success' ? 'bg-green-100 text-green-800' : '' }}
                                    {{ label == 'error' ? 'bg-red-100 text-red-800' : '' }}
                                    {{ label == 'warning' ? 'bg-yellow-100 text-yellow-800' : '' }}
                                    {{ label == 'info' ? 'bg-blue-100 text-blue-800' : '' }}"
                                 role="alert">
                                <span class="flex-1">{{ message }}</span>
                                <button type="button"
                                        data-action="click->flash#dismiss"
                                        class="shrink-0 rounded-md p-1 hover:bg-black/10 focus:outline-none focus:ring-2 focus:ring-current/30"
                                        aria-label="{{ 'flash.dismiss'|trans }}">
                                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                                    </svg>
                                </button>
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>
            {% endif %}
        {% endblock %}

        <main class="min-h-full">
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
