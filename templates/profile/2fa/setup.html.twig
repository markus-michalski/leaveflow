{% extends 'base.html.twig' %}

{% block title %}{{ 'profile.2fa.setup.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-2xl p-6">
    <header class="mb-6">
        <h1 class="text-2xl font-semibold text-gray-900">{{ 'profile.2fa.setup.heading'|trans }}</h1>
        <p class="mt-2 text-xs text-gray-600">{{ 'profile.2fa.setup.intro'|trans }}</p>
    </header>

    <section class="rounded-xl bg-white p-6 shadow-sm">
        <ol class="space-y-6 text-sm text-gray-700">
            <li>
                <p class="font-medium text-gray-900">{{ 'profile.2fa.setup.step1.title'|trans }}</p>
                <p class="mt-1 text-xs text-gray-500">{{ 'profile.2fa.setup.step1.description'|trans }}</p>
            </li>
            <li>
                <p class="font-medium text-gray-900">{{ 'profile.2fa.setup.step2.title'|trans }}</p>
                <p class="mt-1 text-xs text-gray-500">{{ 'profile.2fa.setup.step2.description'|trans }}</p>
                <div class="mt-3 flex flex-col gap-4 sm:flex-row sm:items-start">
                    <div class="flex-shrink-0 rounded-md border border-gray-200 bg-white p-2"
                         data-testid="2fa-setup-qr">
                        {{ qrSvg|raw }}
                    </div>
                    <div class="flex-1">
                        <p class="text-xs text-gray-500">{{ 'profile.2fa.setup.step2.manual_hint'|trans }}</p>
                        <code class="mt-2 block break-all rounded-md border border-gray-200 bg-gray-50 px-3 py-2 font-mono text-xs text-gray-800"
                              data-testid="2fa-setup-secret">{{ secret }}</code>
                    </div>
                </div>
            </li>
            <li>
                <p class="font-medium text-gray-900">{{ 'profile.2fa.setup.step3.title'|trans }}</p>
                <p class="mt-1 text-xs text-gray-500">{{ 'profile.2fa.setup.step3.description'|trans }}</p>

                {% for message in app.flashes('error') %}
                    <div class="mt-3 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800" data-testid="2fa-setup-error">
                        {{ message }}
                    </div>
                {% endfor %}

                <form method="post"
                      action="{{ path('app_profile_2fa_confirm') }}"
                      class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-end"
                      data-testid="2fa-setup-confirm-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('profile_2fa_confirm') }}">
                    <div class="flex-1">
                        <label for="code" class="block text-xs font-medium text-gray-500">
                            {{ 'profile.2fa.setup.code_label'|trans }}
                        </label>
                        <input id="code"
                               type="text"
                               name="code"
                               inputmode="numeric"
                               pattern="[0-9]{6}"
                               minlength="6"
                               maxlength="6"
                               autocomplete="one-time-code"
                               autofocus
                               required
                               class="mt-1 block w-40 rounded-md border border-gray-300 px-3 py-2 font-mono text-base focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                    </div>
                    <button type="submit"
                            class="whitespace-nowrap rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                        {{ 'profile.2fa.setup.submit'|trans }}
                    </button>
                </form>
            </li>
        </ol>
    </section>

    <p class="mt-4 text-center">
        <a href="{{ path('app_profile') }}" class="text-sm text-gray-600 hover:text-gray-900">
            {{ 'profile.2fa.setup.cancel'|trans }}
        </a>
    </p>
</div>
{% endblock %}
