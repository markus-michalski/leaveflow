{% extends 'base.html.twig' %}

{% block title %}{{ 'profile.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-2xl p-6">
    <header class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-semibold text-gray-900">{{ 'profile.heading'|trans }}</h1>
        <a href="{{ path('app_dashboard') }}"
           class="inline-flex items-center gap-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
            {{ 'nav.home'|trans }}
        </a>
    </header>

    {# 1. Urlaubskonto #}
    {% if employee and balance %}
        <section class="mb-6 rounded-xl bg-white p-6 shadow-sm" data-testid="profile-balance">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-lg font-semibold text-gray-900">{{ 'profile.balance.heading'|trans({ '%year%': balanceYear }) }}</h2>
                <a href="{{ path('app_my_leave_request_index') }}"
                   class="inline-flex items-center whitespace-nowrap rounded-md border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-medium text-blue-700 hover:bg-blue-100">
                    {{ 'profile.balance.my_requests'|trans }}
                </a>
            </div>
            <dl class="grid grid-cols-3 gap-y-1.5 text-sm">
                {# Regular leave #}
                <dt class="col-span-1 font-medium text-gray-700">{{ 'profile.balance.regular'|trans }}</dt>
                <dd class="col-span-2 text-right font-mono text-gray-900" data-testid="profile-balance-regular">{{ balance.regularGranted|number_format(2, ',', '.') }} h</dd>
                {% if balance.regularUsed > 0 %}
                    <dt class="col-span-1 pl-3 text-gray-400">{{ 'profile.balance.used'|trans }}</dt>
                    <dd class="col-span-2 text-right font-mono text-rose-600">−{{ balance.regularUsed|number_format(2, ',', '.') }} h</dd>
                {% endif %}
                <dt class="col-span-1 pl-3 text-gray-500">{{ 'profile.balance.remaining'|trans }}</dt>
                <dd class="col-span-2 text-right font-mono font-medium text-gray-900">{{ balance.regularRemaining|number_format(2, ',', '.') }} h</dd>

                {# Carryover #}
                {% if balance.carryoverGranted > 0 %}
                    <dt class="col-span-3 mt-1 border-t border-gray-100 pt-1"></dt>
                    <dt class="col-span-1 font-medium text-gray-700">{{ 'profile.balance.carryover'|trans }}</dt>
                    <dd class="col-span-2 text-right font-mono text-gray-900" data-testid="profile-balance-carryover">{{ balance.carryoverGranted|number_format(2, ',', '.') }} h</dd>
                    {% if balance.carryoverUsed > 0 %}
                        <dt class="col-span-1 pl-3 text-gray-400">{{ 'profile.balance.used'|trans }}</dt>
                        <dd class="col-span-2 text-right font-mono text-rose-600">−{{ balance.carryoverUsed|number_format(2, ',', '.') }} h</dd>
                    {% endif %}
                    <dt class="col-span-1 pl-3 text-gray-500">{{ 'profile.balance.remaining'|trans }}</dt>
                    <dd class="col-span-2 text-right font-mono font-medium text-gray-900" data-testid="profile-balance-carryover-remaining">{{ balance.carryoverRemaining|number_format(2, ',', '.') }} h</dd>
                    {% if balance.nextExpiry %}
                        <dt class="col-span-1 pl-3 text-gray-400">{{ 'profile.balance.next_expiry'|trans }}</dt>
                        <dd class="col-span-2 text-right text-amber-700" data-testid="profile-balance-expiry">{{ balance.nextExpiry|date('d.m.Y') }}</dd>
                    {% endif %}
                {% endif %}

                {# Total #}
                <dt class="col-span-1 mt-1 border-t border-gray-100 pt-2 font-semibold text-gray-800">{{ 'profile.balance.total'|trans }}</dt>
                <dd class="col-span-2 mt-1 border-t border-gray-100 pt-2 text-right font-mono font-semibold text-gray-900" data-testid="profile-balance-total">{{ balance.totalRemaining|number_format(2, ',', '.') }} h</dd>
            </dl>
        </section>
    {% endif %}

    {# 2. Profilübersicht #}
    <section class="mb-6 rounded-xl bg-white p-6 shadow-sm space-y-4">
        <dl class="grid grid-cols-3 gap-y-3 text-sm">
            <dt class="col-span-1 font-medium text-gray-500">{{ 'profile.email'|trans }}</dt>
            <dd class="col-span-2 text-gray-900" data-testid="profile-email">{{ user.email }}</dd>

            <dt class="col-span-1 font-medium text-gray-500">{{ 'profile.role'|trans }}</dt>
            <dd class="col-span-2 text-gray-900">{{ user.role.label|trans }}</dd>

            {% if employee %}
                <dt class="col-span-1 font-medium text-gray-500">{{ 'profile.full_name'|trans }}</dt>
                <dd class="col-span-2 text-gray-900" data-testid="profile-full-name">{{ employee.fullName }}</dd>

                <dt class="col-span-1 font-medium text-gray-500">{{ 'profile.employee_number'|trans }}</dt>
                <dd class="col-span-2 text-gray-900">{{ employee.employeeNumber }}</dd>

                <dt class="col-span-1 font-medium text-gray-500">{{ 'profile.location'|trans }}</dt>
                <dd class="col-span-2 text-gray-900">
                    {{ employee.location.name }}
                    <span class="text-xs text-gray-500">({{ employee.location.city }}, {{ employee.location.federalState }})</span>
                </dd>

                <dt class="col-span-1 font-medium text-gray-500">{{ 'profile.weekly_hours'|trans }}</dt>
                <dd class="col-span-2 text-gray-900">{{ employee.workSchedule.weeklyHours }} h</dd>

                <dt class="col-span-1 font-medium text-gray-500">{{ 'profile.working_days'|trans }}</dt>
                <dd class="col-span-2 text-gray-900">
                    {% for day in employee.workSchedule.workingDays %}
                        <span class="inline-block rounded-full bg-blue-100 px-2 py-0.5 text-xs text-blue-800">{{ ('weekday.' ~ day.name|lower)|trans }}</span>
                    {% endfor %}
                </dd>

                <dt class="col-span-1 font-medium text-gray-500">{{ 'profile.joined_at'|trans }}</dt>
                <dd class="col-span-2 text-gray-900">{{ employee.joinedAt|date('Y-m-d') }}</dd>

                {% if employee.leftAt %}
                    <dt class="col-span-1 font-medium text-gray-500">{{ 'profile.left_at'|trans }}</dt>
                    <dd class="col-span-2 text-gray-900">{{ employee.leftAt|date('Y-m-d') }}</dd>
                {% endif %}
            {% else %}
                <dt class="col-span-3 mt-4 rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900" data-testid="profile-no-employee">
                    {{ 'profile.no_employee_record'|trans }}
                </dt>
            {% endif %}
        </dl>
    </section>

    {# 3. Sprache #}
    <section class="mb-6 rounded-xl bg-white p-6 shadow-sm" data-testid="profile-locale">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">{{ 'profile.locale.heading'|trans }}</h2>
        {{ form_start(localeForm, { action: path('app_profile_locale'), method: 'POST', attr: { class: 'flex items-center gap-4' } }) }}
            <div class="flex-1">
                {{ form_widget(localeForm.locale, { attr: { class: 'rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500' } }) }}
            </div>
            <button type="submit"
                    class="inline-flex items-center whitespace-nowrap rounded-md border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-medium text-blue-700 hover:bg-blue-100"
                    data-testid="profile-locale-save">
                {{ 'profile.settings.adjust'|trans }}
            </button>
        {{ form_end(localeForm) }}
    </section>

    {# 4. Einstellungen #}
    <section class="mb-6 rounded-xl bg-white p-6 shadow-sm" data-testid="profile-settings">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">{{ 'profile.settings.heading'|trans }}</h2>
        <ul class="divide-y divide-gray-100">
            <li class="flex items-center justify-between gap-4 py-3">
                <div>
                    <p class="text-sm font-medium text-gray-900">{{ 'profile.settings.notifications.label'|trans }}</p>
                    <p class="mt-0.5 text-xs text-gray-600">{{ 'profile.settings.notifications.description'|trans }}</p>
                </div>
                <a href="{{ path('app_my_notification_preferences') }}"
                   class="inline-flex items-center whitespace-nowrap rounded-md border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-medium text-blue-700 hover:bg-blue-100"
                   data-testid="profile-settings-notifications">
                    {{ 'profile.settings.adjust'|trans }}
                </a>
            </li>
        </ul>
    </section>

    {# 5. 2FA #}
    <section class="mb-6 rounded-xl bg-white p-6 shadow-sm" data-testid="profile-2fa">
        <h2 class="mb-2 text-lg font-semibold text-gray-900">{{ 'profile.2fa.heading'|trans }}</h2>
        <p class="mb-4 text-sm text-gray-600">{{ 'profile.2fa.description'|trans }}</p>

        {% if user.isTotpEnabled() %}
            <div class="rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800"
                 data-testid="profile-2fa-status-enabled">
                <p class="font-semibold">{{ 'profile.2fa.status.enabled'|trans }}</p>
                <p class="mt-1 text-xs">{{ 'profile.2fa.status.enabled_detail'|trans }}</p>
            </div>

            <div class="mt-4 space-y-3">
                <details data-testid="profile-2fa-regenerate">
                    <summary class="cursor-pointer text-sm text-gray-700 hover:text-gray-900">{{ 'profile.2fa.regenerate.summary'|trans }}</summary>
                    <p class="mt-2 text-xs text-gray-500">{{ 'profile.2fa.regenerate.description'|trans }}</p>
                    <form method="post"
                          action="{{ path('app_profile_2fa_regenerate_codes') }}"
                          class="mt-3 flex flex-col gap-2 sm:flex-row sm:items-end">
                        <input type="hidden" name="_token" value="{{ csrf_token('profile_2fa_regenerate') }}">
                        <div class="flex-1">
                            <label for="regenerate-code" class="block text-xs text-gray-500">{{ 'profile.2fa.code_label'|trans }}</label>
                            <input id="regenerate-code"
                                   type="text"
                                   name="code"
                                   inputmode="numeric"
                                   minlength="6"
                                   maxlength="8"
                                   autocomplete="one-time-code"
                                   required
                                   class="mt-1 block w-40 rounded-md border border-gray-300 px-3 py-2 font-mono text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                        </div>
                        <button type="submit"
                                class="whitespace-nowrap rounded-md border border-yellow-300 bg-yellow-50 px-3 py-2 text-xs font-medium text-yellow-900 hover:bg-yellow-100">
                            {{ 'profile.2fa.regenerate.button'|trans }}
                        </button>
                    </form>
                </details>

                <details data-testid="profile-2fa-disable">
                    <summary class="cursor-pointer text-sm text-red-700 hover:text-red-900">{{ 'profile.2fa.disable.summary'|trans }}</summary>
                    <p class="mt-2 text-xs text-gray-500">{{ 'profile.2fa.disable.description'|trans }}</p>
                    <form method="post"
                          action="{{ path('app_profile_2fa_disable') }}"
                          class="mt-3 flex flex-col gap-2 sm:flex-row sm:items-end"
                          onsubmit="return confirm('{{ 'profile.2fa.disable.confirm'|trans|e('js') }}');">
                        <input type="hidden" name="_token" value="{{ csrf_token('profile_2fa_disable') }}">
                        <div class="flex-1">
                            <label for="disable-code" class="block text-xs text-gray-500">{{ 'profile.2fa.code_label'|trans }}</label>
                            <input id="disable-code"
                                   type="text"
                                   name="code"
                                   inputmode="numeric"
                                   minlength="6"
                                   maxlength="8"
                                   autocomplete="one-time-code"
                                   required
                                   class="mt-1 block w-40 rounded-md border border-gray-300 px-3 py-2 font-mono text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                        </div>
                        <button type="submit"
                                class="whitespace-nowrap rounded-md border border-red-300 bg-red-50 px-3 py-2 text-xs font-medium text-red-700 hover:bg-red-100">
                            {{ 'profile.2fa.disable.button'|trans }}
                        </button>
                    </form>
                </details>
            </div>
        {% else %}
            {% if user.company.requiresTwoFactor() %}
                {% set enforced = user.company.isTwoFactorEnforced(date()) %}
                <div class="mb-4 rounded-md border {{ enforced ? 'border-red-200 bg-red-50 text-red-800' : 'border-yellow-200 bg-yellow-50 text-yellow-800' }} px-4 py-3 text-sm"
                     data-testid="profile-2fa-company-banner">
                    <p class="font-semibold">
                        {{ enforced ? 'profile.2fa.required.now_title'|trans : 'profile.2fa.required.upcoming_title'|trans }}
                    </p>
                    <p class="mt-1 text-xs">
                        {% if enforced %}
                            {{ 'profile.2fa.required.now_detail'|trans }}
                        {% else %}
                            {{ 'profile.2fa.required.upcoming_detail'|trans({ '%date%': user.company.twoFactorEnforcedFrom|date('d.m.Y') }) }}
                        {% endif %}
                    </p>
                </div>
            {% endif %}

            <a href="{{ path('app_profile_2fa_setup') }}"
               class="inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
               data-testid="profile-2fa-enable">
                {{ 'profile.2fa.enable.button'|trans }}
            </a>
        {% endif %}
    </section>

    {# 6. Kalender abonnieren #}
    {% if icalToken is not null %}
        <section class="mb-6 rounded-xl bg-white p-6 shadow-sm" data-testid="profile-ical">
            <h2 class="mb-2 text-lg font-semibold text-gray-900">{{ 'profile.ical.heading'|trans }}</h2>
            <p class="mb-4 text-sm text-gray-600">{{ 'profile.ical.description'|trans }}</p>

            <div class="space-y-4">
                {# Each URL gets its own Stimulus scope so the copy-to-clipboard
                   target stays unambiguous when two source targets coexist. #}
                <div data-controller="copy-to-clipboard">
                    <p class="text-sm font-medium text-gray-900">{{ 'profile.ical.personal.label'|trans }}</p>
                    <p class="mt-0.5 text-xs text-gray-500">{{ 'profile.ical.personal.description'|trans }}</p>
                    <div class="mt-2 flex flex-col gap-2 sm:flex-row sm:items-stretch">
                        <input
                            type="text"
                            readonly
                            value="{{ url('app_ical_personal', { token: icalToken }) }}"
                            class="flex-1 rounded-md border border-gray-300 bg-gray-50 px-3 py-2 font-mono text-xs text-gray-700"
                            data-copy-to-clipboard-target="source"
                            data-testid="profile-ical-personal-url"
                            onclick="this.select()">
                        <button type="button"
                                class="whitespace-nowrap rounded-md border border-gray-300 bg-white px-3 py-2 text-xs font-medium text-gray-700 hover:bg-gray-50"
                                data-action="copy-to-clipboard#copy">
                            {{ 'profile.ical.copy'|trans }}
                        </button>
                    </div>
                </div>

                {% if icalHasTeam %}
                    <div data-controller="copy-to-clipboard">
                        <p class="text-sm font-medium text-gray-900">{{ 'profile.ical.team.label'|trans }}</p>
                        <p class="mt-0.5 text-xs text-gray-500">{{ 'profile.ical.team.description'|trans }}</p>
                        <div class="mt-2 flex flex-col gap-2 sm:flex-row sm:items-stretch">
                            <input
                                type="text"
                                readonly
                                value="{{ url('app_ical_team', { token: icalToken }) }}"
                                class="flex-1 rounded-md border border-gray-300 bg-gray-50 px-3 py-2 font-mono text-xs text-gray-700"
                                data-copy-to-clipboard-target="source"
                                data-testid="profile-ical-team-url"
                                onclick="this.select()">
                            <button type="button"
                                    class="whitespace-nowrap rounded-md border border-gray-300 bg-white px-3 py-2 text-xs font-medium text-gray-700 hover:bg-gray-50"
                                    data-action="copy-to-clipboard#copy">
                                {{ 'profile.ical.copy'|trans }}
                            </button>
                        </div>
                    </div>
                {% endif %}

                <details class="mt-2 text-xs text-gray-500">
                    <summary class="cursor-pointer text-gray-600 hover:text-gray-900">{{ 'profile.ical.reset.summary'|trans }}</summary>
                    <p class="mt-2">{{ 'profile.ical.reset.description'|trans }}</p>
                    <form method="post"
                          action="{{ path('app_profile_ical_reset') }}"
                          class="mt-3"
                          onsubmit="return confirm('{{ 'profile.ical.reset.confirm'|trans|e('js') }}');"
                          data-testid="profile-ical-reset-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('profile_ical_reset') }}">
                        <button type="submit"
                                class="inline-flex items-center whitespace-nowrap rounded-md border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-medium text-red-700 hover:bg-red-100">
                            {{ 'profile.ical.reset.button'|trans }}
                        </button>
                    </form>
                </details>
            </div>
        </section>
    {% endif %}
</div>
{% endblock %}
