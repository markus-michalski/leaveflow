{# One notification row. Two forms side-by-side: the main row marks as read +
   redirects to the deeplink (resolved by the controller); the trailing delete
   button hard-removes the notification. Visual state reflects read/unread. #}
{% set typeValue = notification.type.value %}
<li class="relative {{ notification.isRead ? 'bg-white' : 'bg-blue-50' }}">
    <div class="flex items-stretch">
        <form method="post"
              action="{{ path('app_my_notification_read', { id: notification.id }) }}"
              class="block flex-1 hover:bg-gray-50 focus-within:bg-gray-50">
            <input type="hidden" name="_token" value="{{ csrf_token('notification-read-' ~ notification.id) }}">
            <button type="submit"
                    class="block w-full px-4 py-4 text-left focus:outline-none"
                    data-testid="notification-item-{{ notification.id }}">
                <div class="flex items-start gap-4">
                    <div class="flex-shrink-0 pt-1">
                        {{ include('my/notifications/_icon.html.twig', { type: typeValue }) }}
                    </div>
                    <div class="flex-1 min-w-0">
                        {{ include('my/notifications/_item_' ~ typeValue ~ '.html.twig', { payload: notification.payload }) }}
                        <p class="mt-1 text-xs text-gray-500" data-testid="notification-time">
                            {{ notification.createdAt|date('d.m.Y H:i') }}
                        </p>
                    </div>
                    {% if not notification.isRead %}
                        <span class="ml-2 flex-shrink-0 rounded-full bg-blue-600 px-2 py-0.5 text-xs font-medium text-white"
                              data-testid="notification-unread-badge">
                            {{ 'notifications.inbox.unread_label'|trans({}, 'notifications') }}
                        </span>
                    {% endif %}
                </div>
            </button>
        </form>
        <form method="post"
              action="{{ path('app_my_notification_delete', { id: notification.id }) }}"
              class="flex items-stretch border-l border-gray-100"
              data-testid="notification-delete-form-{{ notification.id }}">
            <input type="hidden" name="_token" value="{{ csrf_token('notification-delete-' ~ notification.id) }}">
            <button type="submit"
                    class="px-4 text-gray-400 hover:bg-rose-50 hover:text-rose-600 focus:outline-none focus:bg-rose-50 focus:text-rose-600"
                    aria-label="{{ 'notifications.inbox.delete_aria_label'|trans({}, 'notifications') }}"
                    data-testid="notification-delete-{{ notification.id }}">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </form>
    </div>
</li>
