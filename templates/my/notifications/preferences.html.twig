{% extends 'base.html.twig' %}

{% block title %}{{ 'notifications.preferences.title'|trans({}, 'notifications') }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl p-6">
    <header class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">
                {{ 'notifications.preferences.heading'|trans({}, 'notifications') }}
            </h1>
            <p class="mt-1 text-sm text-gray-600">
                {{ 'notifications.preferences.intro'|trans({}, 'notifications') }}
            </p>
        </div>
        <div class="flex items-center gap-3">
            <a href="{{ path('app_my_notification_index') }}"
               class="inline-flex items-center gap-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                {{ 'notifications.preferences.back_to_inbox'|trans({}, 'notifications') }}
            </a>
        </div>
    </header>

    <form method="post" action="{{ path('app_my_notification_preferences_save') }}"
          class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm"
          data-testid="my-notification-preferences-form">
        <input type="hidden" name="_token" value="{{ csrf_token('notifications-preferences') }}">

        <div class="border-b border-gray-200 bg-gray-50 px-6 py-3">
            <h2 class="text-sm font-semibold text-gray-900">
                {{ 'notifications.preferences.email_section.heading'|trans({}, 'notifications') }}
            </h2>
            <p class="mt-1 text-xs text-gray-600">
                {{ 'notifications.preferences.email_section.hint'|trans({}, 'notifications') }}
            </p>
        </div>

        <ul class="divide-y divide-gray-200" data-testid="notification-preferences-list">
            {% for type in types %}
                {% set typeValue = type.value %}
                {% set existing = preferencesByType[typeValue]|default(null) %}
                {# Default behavior is "enabled" — checked unless a row says otherwise. #}
                {% set isEnabled = existing is null or existing.isEmailEnabled() %}
                <li class="flex items-start justify-between gap-6 px-6 py-4">
                    <div>
                        <p class="text-sm font-medium text-gray-900">
                            {{ ('notifications.preferences.types.' ~ typeValue ~ '.label')|trans({}, 'notifications') }}
                        </p>
                        <p class="mt-1 text-xs text-gray-600">
                            {{ ('notifications.preferences.types.' ~ typeValue ~ '.description')|trans({}, 'notifications') }}
                        </p>
                    </div>
                    <label class="relative inline-flex cursor-pointer items-center">
                        <input type="checkbox"
                               name="email[{{ typeValue }}]"
                               value="1"
                               {% if isEnabled %}checked{% endif %}
                               class="peer sr-only"
                               data-testid="pref-email-{{ typeValue }}">
                        <span class="h-6 w-11 rounded-full bg-gray-300 transition peer-checked:bg-blue-600"></span>
                        <span class="absolute left-1 top-1 h-4 w-4 rounded-full bg-white transition peer-checked:translate-x-5"></span>
                        <span class="sr-only">
                            {{ ('notifications.preferences.types.' ~ typeValue ~ '.label')|trans({}, 'notifications') }}
                        </span>
                    </label>
                </li>
            {% endfor %}
        </ul>

        <div class="flex items-center justify-end gap-3 border-t border-gray-200 bg-gray-50 px-6 py-4">
            <button type="submit"
                    class="inline-flex items-center gap-1 rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
                    data-testid="notification-preferences-save">
                {{ 'notifications.preferences.save'|trans({}, 'notifications') }}
            </button>
        </div>
    </form>
</div>
{% endblock %}
