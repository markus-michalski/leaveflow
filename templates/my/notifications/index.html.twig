{% extends 'base.html.twig' %}

{% block title %}{{ 'notifications.inbox.title'|trans({}, 'notifications') }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl p-6">
    <header class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">
                {{ 'notifications.inbox.heading'|trans({}, 'notifications') }}
            </h1>
            {% if unreadCount > 0 %}
                <p class="mt-1 text-sm text-gray-600">
                    {{ 'notifications.inbox.unread_count'|trans({ '%count%': unreadCount }, 'notifications') }}
                </p>
            {% endif %}
        </div>
        <div class="flex flex-wrap items-center justify-end gap-3">
            <a href="{{ path('app_dashboard') }}"
               class="inline-flex items-center gap-1 whitespace-nowrap rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                {{ 'nav.home'|trans }}
            </a>
            <a href="{{ path('app_my_notification_preferences') }}"
               class="inline-flex items-center gap-1 whitespace-nowrap rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"
               data-testid="notifications-preferences-link">
                {{ 'notifications.inbox.preferences_link'|trans({}, 'notifications') }}
            </a>
            {% if unreadCount > 0 %}
                <form method="post" action="{{ path('app_my_notification_read_all') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('notifications-read-all') }}">
                    <button type="submit"
                            class="inline-flex items-center gap-1 whitespace-nowrap rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700"
                            data-testid="notifications-mark-all-read">
                        {{ 'notifications.inbox.mark_all_read'|trans({}, 'notifications') }}
                    </button>
                </form>
            {% endif %}
            {% if readCount > 0 %}
                <form method="post"
                      action="{{ path('app_my_notification_delete_read') }}"
                      data-testid="notifications-delete-read-form"
                      data-turbo-confirm="{{ 'notifications.inbox.delete_read_confirm'|trans({}, 'notifications') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('notifications-delete-read') }}">
                    <button type="submit"
                            class="inline-flex items-center gap-1 whitespace-nowrap rounded-md border border-rose-200 bg-white px-3 py-2 text-sm font-medium text-rose-700 hover:bg-rose-50"
                            data-testid="notifications-delete-read">
                        {{ 'notifications.inbox.delete_read'|trans({}, 'notifications') }}
                    </button>
                </form>
            {% endif %}
        </div>
    </header>

    {% if notifications is empty %}
        <div class="rounded-lg border border-dashed border-gray-300 bg-white p-12 text-center"
             data-testid="notifications-empty">
            <p class="text-sm text-gray-600">{{ 'notifications.inbox.empty'|trans({}, 'notifications') }}</p>
        </div>
    {% else %}
        <ul class="divide-y divide-gray-200 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm"
            data-testid="notifications-list">
            {% for notification in notifications %}
                {{ include('my/notifications/_item.html.twig', { notification: notification }) }}
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}
