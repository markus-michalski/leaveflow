{% extends 'base.html.twig' %}

{% block title %}{{ 'my.leave_requests.show.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl p-6">
    <header class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <h1 class="text-2xl font-semibold text-gray-900">{{ 'my.leave_requests.show.heading'|trans }}</h1>
        <div class="flex items-center gap-2">
            {% if leaveRequest.status.value in ['pending', 'recorded'] %}
                <form method="post"
                      action="{{ path('app_my_leave_request_cancel', { id: leaveRequest.id }) }}"
                      onsubmit="return confirm('{{ 'my.leave_requests.show.cancel_confirm'|trans }}')"
                      class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('cancel-leave-request-' ~ leaveRequest.id) }}">
                    <button type="submit"
                            data-testid="leave-request-cancel"
                            class="inline-flex items-center gap-1 rounded-md border border-rose-300 bg-rose-50 px-3 py-2 text-sm font-medium text-rose-700 hover:bg-rose-100">
                        {{ 'my.leave_requests.show.cancel'|trans }}
                    </button>
                </form>
            {% elseif leaveRequest.status.value == 'approved' and canRequestCancel %}
                <form method="post"
                      action="{{ path('app_my_leave_request_request_cancel', { id: leaveRequest.id }) }}"
                      onsubmit="return confirm('{{ 'my.leave_requests.show.request_cancel_confirm'|trans }}')"
                      class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('request-cancel-leave-request-' ~ leaveRequest.id) }}">
                    <button type="submit"
                            data-testid="leave-request-request-cancel"
                            class="inline-flex items-center gap-1 rounded-md border border-orange-300 bg-orange-50 px-3 py-2 text-sm font-medium text-orange-700 hover:bg-orange-100">
                        {{ 'my.leave_requests.show.request_cancel'|trans }}
                    </button>
                </form>
            {% endif %}
            <a href="{{ path('app_my_leave_request_index') }}"
               class="inline-flex items-center gap-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                {{ 'nav.back_to_list'|trans }}
            </a>
        </div>
    </header>

    <section class="rounded-xl bg-white p-6 shadow-sm">
        <dl class="grid grid-cols-3 gap-y-3 text-sm">
            <dt class="col-span-1 font-medium text-gray-500">{{ 'my.leave_requests.field.status'|trans }}</dt>
            <dd class="col-span-2">
                {% set status_classes = {
                    'pending': 'bg-amber-100 text-amber-800',
                    'recorded': 'bg-sky-100 text-sky-800',
                    'approved': 'bg-green-100 text-green-800',
                    'rejected': 'bg-rose-100 text-rose-800',
                    'cancelled': 'bg-gray-100 text-gray-700',
                    'cancel_requested': 'bg-orange-100 text-orange-800',
                } %}
                <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium {{ status_classes[leaveRequest.status.value]|default('bg-gray-100 text-gray-700') }}">
                    {{ ('my.leave_requests.status.' ~ leaveRequest.status.value)|trans }}
                </span>
            </dd>

            <dt class="col-span-1 font-medium text-gray-500">{{ 'my.leave_requests.field.range'|trans }}</dt>
            <dd class="col-span-2 text-gray-900">
                {{ leaveRequest.startDate|date('d.m.Y') }}
                {% if leaveRequest.startDate != leaveRequest.endDate %}
                    – {{ leaveRequest.endDate|date('d.m.Y') }}
                {% endif %}
                {% if leaveRequest.dayType.value != 'full_day' %}
                    <span class="ml-2 inline-flex items-center rounded-md bg-blue-50 px-1.5 py-0.5 text-xs font-medium text-blue-700">
                        {{ ('my.leave_requests.day_type.' ~ leaveRequest.dayType.value)|trans }}
                    </span>
                {% endif %}
            </dd>

            <dt class="col-span-1 font-medium text-gray-500">{{ 'my.leave_requests.field.absence_type'|trans }}</dt>
            <dd class="col-span-2 text-gray-900">
                <span class="inline-flex items-center gap-1">
                    <span class="inline-block h-2.5 w-2.5 rounded-full" style="background-color: {{ leaveRequest.absenceType.color }}"></span>
                    {{ leaveRequest.absenceType.name }}
                </span>
            </dd>

            <dt class="col-span-1 font-medium text-gray-500">{{ 'my.leave_requests.field.hours'|trans }}</dt>
            <dd class="col-span-2 text-gray-900 font-mono" data-testid="leave-request-total-hours">
                {{ leaveRequest.totalHours|number_format(2, ',', '.') }} h
            </dd>

            <dt class="col-span-1 font-medium text-gray-500">{{ 'my.leave_requests.field.requested_at'|trans }}</dt>
            <dd class="col-span-2 text-gray-900">{{ leaveRequest.requestedAt|date('d.m.Y H:i') }}</dd>
        </dl>
    </section>

    {% if auditEntries is not empty %}
        <section class="mt-6 rounded-xl bg-white p-6 shadow-sm" data-testid="my-audit-trail">
            <h2 class="mb-4 text-lg font-semibold text-gray-900">{{ 'my.leave_requests.show.history_heading'|trans }}</h2>
            <ul class="divide-y divide-gray-100 text-sm">
                {% for entry in auditEntries %}
                    {% set isRejection = entry.transition in ['reject', 'deny_cancel'] %}
                    <li class="py-3 flex flex-wrap items-start justify-between gap-2">
                        <div class="flex-1">
                            <span class="font-medium {{ isRejection ? 'text-rose-900' : 'text-gray-900' }}">
                                {{ ('my.leave_requests.history.transition.' ~ entry.transition)|trans }}
                            </span>
                            <span class="ml-2 text-xs text-gray-500">
                                {{ ('my.leave_requests.status.' ~ entry.fromStatus.value)|trans }}
                                →
                                {{ ('my.leave_requests.status.' ~ entry.toStatus.value)|trans }}
                            </span>
                            {% if entry.reason %}
                                <div class="mt-2 rounded-md {{ isRejection ? 'bg-rose-50 border border-rose-200' : 'bg-gray-50' }} p-3">
                                    <p class="text-xs font-medium {{ isRejection ? 'text-rose-800' : 'text-gray-600' }} mb-1">
                                        {{ 'my.leave_requests.history.reason_label'|trans }}
                                    </p>
                                    <p class="text-sm {{ isRejection ? 'text-rose-900' : 'text-gray-800' }} whitespace-pre-line">{{ entry.reason }}</p>
                                </div>
                            {% endif %}
                        </div>
                        <div class="text-xs text-gray-500 text-right shrink-0">
                            {% if entry.actor %}
                                {{ entry.actor.fullName }}
                            {% else %}
                                {{ 'my.leave_requests.history.system'|trans }}
                            {% endif %}
                            <br>
                            {{ entry.occurredAt|date('d.m.Y H:i') }}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}

    <section class="mt-6 rounded-xl bg-white p-6 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold text-gray-900">{{ 'my.leave_requests.show.days_heading'|trans }}</h2>
        <ul class="divide-y divide-gray-100 text-sm">
            {% for day in leaveRequest.days %}
                {% set weekday = day.date.format('N') %}
                {% set weekdayNames = { 1: 'monday', 2: 'tuesday', 3: 'wednesday', 4: 'thursday', 5: 'friday', 6: 'saturday', 7: 'sunday' } %}
                <li class="flex items-center justify-between py-2">
                    <span class="flex items-center gap-2">
                        <span class="inline-block w-24 text-xs uppercase tracking-wide text-gray-500">
                            {{ ('weekday.' ~ weekdayNames[weekday])|trans }}
                        </span>
                        <span class="font-mono text-gray-700">{{ day.date|date('d.m.Y') }}</span>
                    </span>
                    <span class="flex items-center gap-3">
                        {% if day.status.value == 'excluded' %}
                            <span class="text-xs text-gray-500">{{ ('my.leave_requests.exclusion.' ~ day.reason.value)|trans }}</span>
                            <span class="font-mono text-gray-400">0 h</span>
                        {% elseif day.status.value == 'half_day' %}
                            <span class="inline-flex items-center rounded-md bg-blue-50 px-1.5 py-0.5 text-xs font-medium text-blue-700">{{ 'my.leave_requests.preview.half_day'|trans }}</span>
                            <span class="font-mono text-gray-900">{{ day.hours|number_format(2, ',', '.') }} h</span>
                        {% else %}
                            <span class="font-mono text-gray-900">{{ day.hours|number_format(2, ',', '.') }} h</span>
                        {% endif %}
                    </span>
                </li>
            {% endfor %}
        </ul>
    </section>
</div>
{% endblock %}
