{% extends 'base.html.twig' %}

{% block title %}{{ 'my.leave_requests.new.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl p-6">
    <header class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-semibold text-gray-900">{{ 'my.leave_requests.new.heading'|trans }}</h1>
        <a href="{{ path('app_my_leave_request_index') }}"
           class="inline-flex items-center gap-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
            {{ 'nav.back_to_list'|trans }}
        </a>
    </header>

    <section class="rounded-xl bg-white p-6 shadow-sm"
             data-controller="leave-preview"
             data-leave-preview-preview-url-value="{{ path('app_my_leave_request_preview') }}">
        {{ form_start(form, { attr: {
            'data-leave-preview-target': 'form',
            'class': 'space-y-5',
        } }) }}

            <p class="text-sm text-gray-500">{{ 'form.required_legend'|trans }}</p>

            {{ form_errors(form) }}

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                {{ form_row(form.startDate) }}
                {{ form_row(form.endDate) }}
            </div>

            {{ form_row(form.dayType) }}
            {{ form_row(form.absenceType) }}

            <div class="mt-4">
                <h2 class="mb-2 text-sm font-medium text-gray-700">{{ 'my.leave_requests.preview.heading'|trans }}</h2>
                <turbo-frame id="leave-preview"
                             data-leave-preview-target="frame"
                             class="block">
                    <div class="rounded-md border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-sm text-gray-500" data-testid="leave-preview-placeholder">
                        {{ 'my.leave_requests.preview.awaiting_dates'|trans }}
                    </div>
                </turbo-frame>
            </div>

            <div class="mt-6 flex items-center justify-end gap-3">
                <a href="{{ path('app_my_leave_request_index') }}"
                   class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                    {{ 'form.cancel'|trans }}
                </a>
                <button type="submit"
                        data-testid="leave-request-submit"
                        class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                    {{ 'my.leave_requests.new.submit'|trans }}
                </button>
            </div>

        {{ form_end(form) }}
    </section>
</div>
{% endblock %}
