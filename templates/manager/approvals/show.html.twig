{% extends 'base.html.twig' %}

{% block title %}{{ 'manager.approvals.show.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl p-6">
    <header class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-semibold text-gray-900">{{ 'manager.approvals.show.heading'|trans }}</h1>
        <a href="{{ path('app_manager_approval_index') }}"
           class="inline-flex items-center gap-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
            {{ 'nav.back_to_list'|trans }}
        </a>
    </header>

    <section class="rounded-xl bg-white p-6 shadow-sm">
        <dl class="grid grid-cols-3 gap-y-3 text-sm">
            <dt class="col-span-1 font-medium text-gray-500">{{ 'admin.leave_requests.field.employee'|trans }}</dt>
            <dd class="col-span-2 text-gray-900">{{ leaveRequest.employee.fullName }} ({{ leaveRequest.employee.employeeNumber }})</dd>

            <dt class="col-span-1 font-medium text-gray-500">{{ 'my.leave_requests.field.status'|trans }}</dt>
            <dd class="col-span-2">
                {% set status_classes = {
                    'pending': 'bg-amber-100 text-amber-800',
                    'recorded': 'bg-sky-100 text-sky-800',
                    'approved': 'bg-green-100 text-green-800',
                    'rejected': 'bg-rose-100 text-rose-800',
                    'cancelled': 'bg-gray-100 text-gray-700',
                    'cancel_requested': 'bg-orange-100 text-orange-800',
                } %}
                <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium {{ status_classes[leaveRequest.status.value]|default('bg-gray-100 text-gray-700') }}">
                    {{ ('my.leave_requests.status.' ~ leaveRequest.status.value)|trans }}
                </span>
            </dd>

            <dt class="col-span-1 font-medium text-gray-500">{{ 'my.leave_requests.field.range'|trans }}</dt>
            <dd class="col-span-2 text-gray-900">
                {{ leaveRequest.startDate|date('d.m.Y') }}
                {% if leaveRequest.startDate != leaveRequest.endDate %}
                    – {{ leaveRequest.endDate|date('d.m.Y') }}
                {% endif %}
            </dd>

            <dt class="col-span-1 font-medium text-gray-500">{{ 'my.leave_requests.field.absence_type'|trans }}</dt>
            <dd class="col-span-2 text-gray-900">
                <span class="inline-flex items-center gap-1">
                    <span class="inline-block h-2.5 w-2.5 rounded-full" style="background-color: {{ leaveRequest.absenceType.color }}"></span>
                    {{ leaveRequest.absenceType.name }}
                </span>
            </dd>

            <dt class="col-span-1 font-medium text-gray-500">{{ 'my.leave_requests.field.hours'|trans }}</dt>
            <dd class="col-span-2 text-gray-900 font-mono">{{ leaveRequest.totalHours|number_format(2, ',', '.') }} h</dd>

            <dt class="col-span-1 font-medium text-gray-500">{{ 'my.leave_requests.field.requested_at'|trans }}</dt>
            <dd class="col-span-2 text-gray-900">{{ leaveRequest.requestedAt|date('d.m.Y H:i') }}</dd>
        </dl>
    </section>

    {% if leaveRequest.status.value == 'pending' %}
        <section class="mt-6 rounded-xl bg-white p-6 shadow-sm" data-testid="approval-actions-pending">
            <h2 class="mb-4 text-lg font-semibold text-gray-900">{{ 'manager.approvals.actions.heading'|trans }}</h2>
            <div class="flex flex-wrap items-start gap-4">
                <form method="post" action="{{ path('app_manager_approval_approve', { id: leaveRequest.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('approve-leave-request-' ~ leaveRequest.id) }}">
                    <button type="submit"
                            data-testid="approve-button"
                            class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">
                        {{ 'manager.approvals.actions.approve'|trans }}
                    </button>
                </form>

                <div class="flex-1 min-w-[260px] rounded-md border border-rose-200 bg-rose-50 p-4">
                    {{ form_start(rejectForm, { action: path('app_manager_approval_reject', { id: leaveRequest.id }), attr: { 'data-testid': 'reject-form', class: 'space-y-3' } }) }}
                        {{ form_row(rejectForm.reason, { label_attr: { class: 'block text-sm font-medium text-rose-800' }, attr: { class: 'mt-1 block w-full rounded-md border border-rose-300 px-3 py-2' } }) }}
                        <button type="submit"
                                data-testid="reject-button"
                                class="rounded-md bg-rose-600 px-4 py-2 text-sm font-medium text-white hover:bg-rose-700">
                            {{ 'manager.approvals.actions.reject'|trans }}
                        </button>
                    {{ form_end(rejectForm) }}
                </div>
            </div>
        </section>
    {% elseif leaveRequest.status.value == 'cancel_requested' %}
        <section class="mt-6 rounded-xl bg-white p-6 shadow-sm" data-testid="approval-actions-cancel-requested">
            <h2 class="mb-4 text-lg font-semibold text-gray-900">{{ 'manager.approvals.actions.cancel_heading'|trans }}</h2>
            <p class="mb-4 text-sm text-gray-600">{{ 'manager.approvals.actions.cancel_intro'|trans }}</p>
            <div class="flex flex-wrap gap-3">
                <form method="post" action="{{ path('app_manager_approval_confirm_cancel', { id: leaveRequest.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('confirm-cancel-leave-request-' ~ leaveRequest.id) }}">
                    <button type="submit"
                            data-testid="confirm-cancel-button"
                            class="rounded-md bg-gray-700 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800">
                        {{ 'manager.approvals.actions.confirm_cancel'|trans }}
                    </button>
                </form>
                <form method="post" action="{{ path('app_manager_approval_deny_cancel', { id: leaveRequest.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('deny-cancel-leave-request-' ~ leaveRequest.id) }}">
                    <button type="submit"
                            data-testid="deny-cancel-button"
                            class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                        {{ 'manager.approvals.actions.deny_cancel'|trans }}
                    </button>
                </form>
            </div>
        </section>
    {% endif %}

    <section class="mt-6 rounded-xl bg-white p-6 shadow-sm" data-testid="audit-trail">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">{{ 'manager.approvals.history.heading'|trans }}</h2>
        {% if auditEntries is empty %}
            <p class="text-sm text-gray-500" data-testid="audit-trail-empty">{{ 'manager.approvals.history.empty'|trans }}</p>
        {% else %}
            <ul class="divide-y divide-gray-100 text-sm">
                {% for entry in auditEntries %}
                    <li class="py-2 flex flex-wrap items-start justify-between gap-2">
                        <div>
                            <span class="font-medium text-gray-900">{{ ('manager.approvals.transitions.' ~ entry.transition)|trans }}</span>
                            <span class="ml-2 text-xs text-gray-500">
                                {{ ('my.leave_requests.status.' ~ entry.fromStatus.value)|trans }}
                                →
                                {{ ('my.leave_requests.status.' ~ entry.toStatus.value)|trans }}
                            </span>
                            {% if entry.reason %}
                                <p class="mt-1 text-sm text-gray-700 whitespace-pre-line">{{ entry.reason }}</p>
                            {% endif %}
                        </div>
                        <div class="text-xs text-gray-500 text-right">
                            {% if entry.actor %}
                                {{ entry.actor.fullName }}
                            {% else %}
                                {{ 'manager.approvals.history.system'|trans }}
                            {% endif %}
                            <br>
                            {{ entry.occurredAt|date('d.m.Y H:i') }}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>
</div>
{% endblock %}
