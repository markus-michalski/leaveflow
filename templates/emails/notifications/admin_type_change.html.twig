{% extends 'emails/notifications/base.html.twig' %}

{% block title %}{{ 'email.admin_type_change.subject'|trans({
    '%oldTypeName%': payload.oldTypeName,
    '%newTypeName%': payload.newTypeName,
}, 'notifications') }}{% endblock %}

{% block body %}
    <h2 style="margin: 0 0 16px; font-size: 18px; color: #111827;">
        {{ 'email.admin_type_change.heading'|trans({}, 'notifications') }}
    </h2>
    <p style="margin: 0 0 16px;">
        {{ 'email.admin_type_change.intro'|trans({
            '%oldTypeName%': payload.oldTypeName,
            '%newTypeName%': payload.newTypeName,
            '%adminName%': payload.adminName,
        }, 'notifications')|raw }}
    </p>
    <table role="presentation" cellpadding="0" cellspacing="0" style="margin: 16px 0; border-collapse: collapse;">
        <tr>
            <td style="padding: 8px 16px 8px 0; color: #6b7280;">{{ 'email.field.absence_type_old'|trans({}, 'notifications') }}</td>
            <td style="padding: 8px 0; font-weight: 500;">{{ payload.oldTypeName }}</td>
        </tr>
        <tr>
            <td style="padding: 8px 16px 8px 0; color: #6b7280;">{{ 'email.field.absence_type_new'|trans({}, 'notifications') }}</td>
            <td style="padding: 8px 0; font-weight: 500;">{{ payload.newTypeName }}</td>
        </tr>
        <tr>
            <td style="padding: 8px 16px 8px 0; color: #6b7280;">{{ 'email.field.period'|trans({}, 'notifications') }}</td>
            <td style="padding: 8px 0; font-weight: 500;">{{ payload.startDate }} – {{ payload.endDate }}</td>
        </tr>
        <tr>
            <td style="padding: 8px 16px 8px 0; color: #6b7280;">{{ 'email.field.reason'|trans({}, 'notifications') }}</td>
            <td style="padding: 8px 0; font-weight: 500;">{{ payload.reason }}</td>
        </tr>
    </table>
    <p style="margin: 16px 0 0; color: #6b7280; font-size: 13px;">
        {{ 'email.admin_type_change.outro'|trans({}, 'notifications') }}
    </p>
{% endblock %}
