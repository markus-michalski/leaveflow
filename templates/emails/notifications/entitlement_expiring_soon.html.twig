{% extends 'emails/notifications/base.html.twig' %}

{% block title %}{{ 'email.entitlement_expiring_soon.subject'|trans(payload, 'notifications') }}{% endblock %}

{% block body %}
    <h2 style="margin: 0 0 16px; font-size: 18px; color: #111827;">
        {{ 'email.entitlement_expiring_soon.heading'|trans({}, 'notifications') }}
    </h2>
    <p style="margin: 0 0 16px;">
        {{ 'email.entitlement_expiring_soon.intro'|trans({
            '%hoursRemaining%': payload.hoursRemaining,
            '%expiresAt%': payload.expiresAt,
            '%daysRemaining%': payload.daysRemaining,
            '%year%': payload.year,
        }, 'notifications')|raw }}
    </p>
    <table role="presentation" cellpadding="0" cellspacing="0" style="margin: 16px 0; border-collapse: collapse;">
        <tr>
            <td style="padding: 8px 16px 8px 0; color: #6b7280;">{{ 'email.field.expires_at'|trans({}, 'notifications') }}</td>
            <td style="padding: 8px 0; font-weight: 500;">{{ payload.expiresAt }}</td>
        </tr>
        <tr>
            <td style="padding: 8px 16px 8px 0; color: #6b7280;">{{ 'email.field.hours_remaining'|trans({}, 'notifications') }}</td>
            <td style="padding: 8px 0; font-weight: 500;">{{ payload.hoursRemaining }}</td>
        </tr>
    </table>
    <p style="margin: 16px 0 0; color: #6b7280; font-size: 13px;">
        {{ 'email.entitlement_expiring_soon.outro'|trans({}, 'notifications') }}
    </p>
{% endblock %}
