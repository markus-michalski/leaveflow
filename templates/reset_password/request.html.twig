{% extends 'base.html.twig' %}

{% block title %}{{ 'security.reset_password.request.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="flex min-h-screen items-center justify-center bg-gray-50 px-4">
    <div class="w-full max-w-md space-y-6 rounded-xl bg-white p-8 shadow-sm">
        <div class="text-center">
            <h1 class="text-2xl font-semibold text-gray-900">
                {{ 'security.reset_password.request.heading'|trans }}
            </h1>
            <p class="mt-2 text-sm text-gray-500">
                {{ 'security.reset_password.request.intro'|trans }}
            </p>
        </div>

        {{ form_start(requestForm, { attr: { class: 'space-y-4', 'data-testid': 'reset-request-form' } }) }}
            {{ form_row(requestForm.email, {
                row_attr: { class: 'space-y-1' },
                label_attr: { class: 'block text-sm font-medium text-gray-700' },
                attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 focus:border-blue-500 focus:ring-blue-500' }
            }) }}

            <button type="submit" class="w-full rounded-md bg-blue-600 px-4 py-2 font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                {{ 'security.reset_password.request.submit'|trans }}
            </button>
        {{ form_end(requestForm) }}

        <div class="text-center text-sm">
            <a href="{{ path('app_login') }}" class="text-blue-600 hover:underline">
                {{ 'security.reset_password.request.back_to_login'|trans }}
            </a>
        </div>
    </div>
</div>
{% endblock %}
