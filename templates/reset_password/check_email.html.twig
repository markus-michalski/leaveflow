{% extends 'base.html.twig' %}

{% block title %}{{ 'security.reset_password.check_email.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block app_header %}{% endblock %}

{% block body %}
<div class="flex min-h-screen items-center justify-center bg-gray-50 px-4">
    <div class="w-full max-w-md space-y-4 rounded-xl bg-white p-8 text-center shadow-sm">
        <h1 class="text-2xl font-semibold text-gray-900">
            {{ 'security.reset_password.check_email.heading'|trans }}
        </h1>
        <p class="text-sm text-gray-600">
            {{ 'security.reset_password.check_email.description'|trans }}
        </p>
        <a href="{{ path('app_login') }}" class="mt-4 inline-block text-blue-600 hover:underline">
            {{ 'security.reset_password.request.back_to_login'|trans }}
        </a>
    </div>
</div>
{% endblock %}
