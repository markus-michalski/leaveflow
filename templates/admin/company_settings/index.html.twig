{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.company_settings.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl p-6">
    <header class="mb-6">
        <h1 class="text-2xl font-semibold text-gray-900">{{ 'admin.company_settings.heading'|trans }}</h1>
        <p class="mt-1 text-sm text-gray-500">{{ 'admin.company_settings.description'|trans }}</p>
    </header>

    {# Profile section — name, address, branding, retention/escalation. #}
    <section class="mb-6 rounded-xl bg-white p-6 shadow-sm" data-testid="company-settings-profile">
        <h2 class="text-lg font-semibold text-gray-900">{{ 'admin.company_settings.profile.heading'|trans }}</h2>
        <p class="mt-1 text-sm text-gray-600">{{ 'admin.company_settings.profile.description'|trans }}</p>

        {% if company.logoPath %}
            <div class="mt-4 flex flex-wrap items-center gap-4 rounded-md border border-gray-200 bg-gray-50 p-3">
                <img src="{{ asset(company.logoPath) }}" alt="{{ company.name }}" class="h-16 w-auto max-w-[12rem] rounded bg-white p-1 shadow-sm" data-testid="company-settings-current-logo">
                <form method="post"
                      action="{{ path('app_admin_company_settings_remove_logo') }}"
                      onsubmit="return confirm('{{ 'admin.company_settings.profile.logo_remove_confirm'|trans|e('js') }}');">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_logo') }}">
                    <button type="submit"
                            class="inline-flex items-center rounded-md border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-medium text-red-700 hover:bg-red-100">
                        {{ 'admin.company_settings.profile.logo_remove'|trans }}
                    </button>
                </form>
            </div>
        {% endif %}

        {# Reusable class blobs so the per-row calls stay readable. Symfony's
           default form-theme renders raw inputs; this project chose per-row
           Tailwind classes (see admin/employees/form.html.twig) over a
           project-wide form theme to keep theme drift to one place. #}
        {% set labelClass = 'block text-sm font-medium text-gray-700' %}
        {% set inputClass = 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500' %}
        {% set rowClass = '' %}

        {{ form_start(form, { attr: { 'data-testid': 'company-settings-profile-form', 'enctype': 'multipart/form-data' } }) }}
            <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="sm:col-span-2">
                    {{ form_row(form.name, {
                        label_attr: { class: labelClass },
                        attr: { class: inputClass },
                    }) }}
                </div>
                <div class="sm:col-span-2">
                    {{ form_row(form.address, {
                        label_attr: { class: labelClass },
                        attr: { class: inputClass ~ ' font-mono', rows: 4 },
                    }) }}
                </div>
                <div>
                    {{ form_row(form.taxId, {
                        label_attr: { class: labelClass },
                        attr: { class: inputClass },
                    }) }}
                </div>
                <div>
                    {{ form_row(form.commercialRegister, {
                        label_attr: { class: labelClass },
                        attr: { class: inputClass },
                    }) }}
                </div>
                <div>
                    {{ form_row(form.primaryColor, {
                        label_attr: { class: labelClass },
                        attr: { class: 'mt-1 h-10 w-24 cursor-pointer rounded-md border border-gray-300 p-1' },
                    }) }}
                </div>
                <div>
                    {{ form_row(form.logo, {
                        label_attr: { class: labelClass },
                        attr: { class: 'mt-1 block w-full text-sm text-gray-700 file:mr-3 file:rounded-md file:border-0 file:bg-blue-50 file:px-3 file:py-2 file:text-xs file:font-medium file:text-blue-700 hover:file:bg-blue-100' },
                    }) }}
                </div>
                <div>
                    {{ form_row(form.retentionPeriodMonths, {
                        label_attr: { class: labelClass },
                        attr: { class: inputClass ~ ' w-32' },
                    }) }}
                </div>
                <div>
                    {{ form_row(form.approvalEscalationDays, {
                        label_attr: { class: labelClass },
                        attr: { class: inputClass ~ ' w-32' },
                    }) }}
                </div>
            </div>

            <div class="mt-6">
                <button type="submit"
                        class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                    {{ 'admin.company_settings.profile.save'|trans }}
                </button>
            </div>
        {{ form_end(form) }}
    </section>

    {# Existing 2FA-requirement section — separate form so file-upload state doesn't bleed into the toggle. #}
    <section class="mb-6 rounded-xl bg-white p-6 shadow-sm" data-testid="company-settings-2fa">
        <h2 class="text-lg font-semibold text-gray-900">{{ 'admin.company_settings.2fa.heading'|trans }}</h2>
        <p class="mt-1 text-sm text-gray-600">{{ 'admin.company_settings.2fa.description'|trans }}</p>

        {% if company.requiresTwoFactor() %}
            {% set enforced = company.isTwoFactorEnforced(today) %}
            <div class="mt-4 rounded-md border {{ enforced ? 'border-green-200 bg-green-50 text-green-800' : 'border-yellow-200 bg-yellow-50 text-yellow-800' }} px-4 py-3 text-sm"
                 data-testid="company-settings-2fa-status">
                <p class="font-semibold">
                    {{ enforced ? 'admin.company_settings.2fa.status.enforced'|trans : 'admin.company_settings.2fa.status.upcoming'|trans }}
                </p>
                <p class="mt-1 text-xs">
                    {{ 'admin.company_settings.2fa.status.detail'|trans({ '%date%': company.twoFactorEnforcedFrom|date('d.m.Y') }) }}
                </p>
            </div>

            <form method="post"
                  action="{{ path('app_admin_company_settings_set_2fa_requirement') }}"
                  class="mt-4"
                  onsubmit="return confirm('{{ 'admin.company_settings.2fa.disable_confirm'|trans|e('js') }}');">
                <input type="hidden" name="_token" value="{{ csrf_token('company_settings_2fa') }}">
                <input type="hidden" name="enable" value="0">
                <button type="submit"
                        class="inline-flex items-center rounded-md border border-red-200 bg-red-50 px-3 py-1.5 text-sm font-medium text-red-700 hover:bg-red-100">
                    {{ 'admin.company_settings.2fa.disable_button'|trans }}
                </button>
            </form>
        {% else %}
            <form method="post"
                  action="{{ path('app_admin_company_settings_set_2fa_requirement') }}"
                  class="mt-4 space-y-3"
                  data-testid="company-settings-2fa-enable-form">
                <input type="hidden" name="_token" value="{{ csrf_token('company_settings_2fa') }}">
                <input type="hidden" name="enable" value="1">
                <div>
                    <label for="enforced_from" class="block text-sm font-medium text-gray-700">
                        {{ 'admin.company_settings.2fa.deadline_label'|trans }}
                    </label>
                    <input id="enforced_from"
                           type="date"
                           name="enforced_from"
                           required
                           min="{{ today|date('Y-m-d') }}"
                           value="{{ (today|date_modify('+30 days'))|date('Y-m-d') }}"
                           class="mt-1 block w-44 rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                    <p class="mt-1 text-xs text-gray-500">{{ 'admin.company_settings.2fa.deadline_hint'|trans }}</p>
                </div>
                <button type="submit"
                        class="inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                    {{ 'admin.company_settings.2fa.enable_button'|trans }}
                </button>
            </form>
        {% endif %}
    </section>

    {# Google Workspace OAuth section #}
    <section class="mb-6 rounded-xl bg-white p-6 shadow-sm" data-testid="company-settings-google">
        <h2 class="text-lg font-semibold text-gray-900">{{ 'admin.company_settings.google.heading'|trans }}</h2>
        <p class="mt-1 text-sm text-gray-600">{{ 'admin.company_settings.google.description'|trans }}</p>

        <div class="mt-4 space-y-4">
            {% if company.isGoogleOAuthEnabled() %}
                <p class="inline-flex items-center gap-2 text-sm font-medium text-green-700">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    {{ 'admin.company_settings.google.status.enabled'|trans }}
                </p>

                {# Save config while keeping Google enabled #}
                <form method="post"
                      action="{{ path('app_admin_company_settings_set_google_oauth') }}"
                      data-testid="company-settings-google-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_google') }}">
                    <input type="hidden" name="enable" value="1">
                    <div>
                        <label for="hosted_domain" class="block text-sm font-medium text-gray-700">
                            {{ 'admin.company_settings.google.hosted_domain_label'|trans }}
                        </label>
                        <input id="hosted_domain"
                               type="text"
                               name="hosted_domain"
                               value="{{ company.googleOAuthHostedDomain ?? '' }}"
                               placeholder="acme.com"
                               class="mt-1 block w-64 rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                        <p class="mt-1 text-xs text-gray-500">{{ 'admin.company_settings.google.hosted_domain_hint'|trans }}</p>
                    </div>
                    <button type="submit"
                            class="mt-3 inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                        {{ 'admin.company_settings.google.save_button'|trans }}
                    </button>
                </form>

                {# Disable Google login (keeps existing hosted_domain) #}
                <form method="post" action="{{ path('app_admin_company_settings_set_google_oauth') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_google') }}">
                    <input type="hidden" name="enable" value="0">
                    <input type="hidden" name="hosted_domain" value="{{ company.googleOAuthHostedDomain ?? '' }}">
                    <button type="submit"
                            class="inline-flex items-center rounded-md border border-red-200 bg-red-50 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-100">
                        {{ 'admin.company_settings.google.disable_button'|trans }}
                    </button>
                </form>
            {% else %}
                <p class="text-sm text-gray-500">{{ 'admin.company_settings.google.status.disabled'|trans }}</p>

                {# Enable Google login + optional hosted domain #}
                <form method="post"
                      action="{{ path('app_admin_company_settings_set_google_oauth') }}"
                      data-testid="company-settings-google-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_google') }}">
                    <input type="hidden" name="enable" value="1">
                    <div>
                        <label for="hosted_domain" class="block text-sm font-medium text-gray-700">
                            {{ 'admin.company_settings.google.hosted_domain_label'|trans }}
                        </label>
                        <input id="hosted_domain"
                               type="text"
                               name="hosted_domain"
                               value="{{ company.googleOAuthHostedDomain ?? '' }}"
                               placeholder="acme.com"
                               class="mt-1 block w-64 rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                        <p class="mt-1 text-xs text-gray-500">{{ 'admin.company_settings.google.hosted_domain_hint'|trans }}</p>
                    </div>
                    <button type="submit"
                            class="mt-3 inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                        {{ 'admin.company_settings.google.enable_button'|trans }}
                    </button>
                </form>
            {% endif %}
        </div>
    </section>

    {# Microsoft Entra ID OAuth section #}
    <section class="mb-6 rounded-xl bg-white p-6 shadow-sm" data-testid="company-settings-entra">
        <h2 class="text-lg font-semibold text-gray-900">{{ 'admin.company_settings.entra.heading'|trans }}</h2>
        <p class="mt-1 text-sm text-gray-600">{{ 'admin.company_settings.entra.description'|trans }}</p>

        <div class="mt-4 space-y-4">
            {% if company.isEntraOAuthEnabled() %}
                <p class="inline-flex items-center gap-2 text-sm font-medium text-green-700">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    {{ 'admin.company_settings.entra.status.enabled'|trans }}
                </p>
                {% if not company.entraOAuthTenantId %}
                    <div class="rounded-md border border-yellow-200 bg-yellow-50 px-4 py-3 text-sm text-yellow-800" data-testid="entra-tenant-warning">
                        <p class="font-semibold">{{ 'admin.company_settings.entra.security_warning.heading'|trans }}</p>
                        <p class="mt-1">{{ 'admin.company_settings.entra.security_warning.body'|trans }}</p>
                    </div>
                {% endif %}

                {# Save Tenant ID while keeping Entra enabled #}
                <form method="post"
                      action="{{ path('app_admin_company_settings_set_entra_oauth') }}"
                      data-testid="company-settings-entra-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_entra') }}">
                    <input type="hidden" name="enable" value="1">
                    <div>
                        <label for="tenant_id" class="block text-sm font-medium text-gray-700">
                            {{ 'admin.company_settings.entra.tenant_id_label'|trans }}
                        </label>
                        <input id="tenant_id"
                               type="text"
                               name="tenant_id"
                               value="{{ company.entraOAuthTenantId ?? '' }}"
                               placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                               class="mt-1 block w-80 rounded-md border border-gray-300 px-3 py-2 text-sm font-mono focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                        <p class="mt-1 text-xs text-gray-500">{{ 'admin.company_settings.entra.tenant_id_hint'|trans }}</p>
                    </div>
                    <button type="submit"
                            class="mt-3 inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                        {{ 'admin.company_settings.entra.save_button'|trans }}
                    </button>
                </form>

                {# Disable Entra login (keeps existing tenant ID) #}
                <form method="post" action="{{ path('app_admin_company_settings_set_entra_oauth') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_entra') }}">
                    <input type="hidden" name="enable" value="0">
                    <input type="hidden" name="tenant_id" value="{{ company.entraOAuthTenantId ?? '' }}">
                    <button type="submit"
                            class="inline-flex items-center rounded-md border border-red-200 bg-red-50 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-100">
                        {{ 'admin.company_settings.entra.disable_button'|trans }}
                    </button>
                </form>
            {% else %}
                <p class="text-sm text-gray-500">{{ 'admin.company_settings.entra.status.disabled'|trans }}</p>

                {# Enable Entra login + optional tenant ID #}
                <form method="post"
                      action="{{ path('app_admin_company_settings_set_entra_oauth') }}"
                      data-testid="company-settings-entra-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_entra') }}">
                    <input type="hidden" name="enable" value="1">
                    <div>
                        <label for="tenant_id" class="block text-sm font-medium text-gray-700">
                            {{ 'admin.company_settings.entra.tenant_id_label'|trans }}
                        </label>
                        <input id="tenant_id"
                               type="text"
                               name="tenant_id"
                               value="{{ company.entraOAuthTenantId ?? '' }}"
                               placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                               class="mt-1 block w-80 rounded-md border border-gray-300 px-3 py-2 text-sm font-mono focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                        <p class="mt-1 text-xs text-gray-500">{{ 'admin.company_settings.entra.tenant_id_hint'|trans }}</p>
                    </div>
                    <button type="submit"
                            class="mt-3 inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                        {{ 'admin.company_settings.entra.enable_button'|trans }}
                    </button>
                </form>
            {% endif %}
        </div>
    </section>

    {# Microsoft Teams Integration #}
    <section class="mb-6 rounded-xl bg-white p-6 shadow-sm" data-testid="company-settings-teams">
        <h2 class="text-lg font-semibold text-gray-900">{{ 'admin.company_settings.teams.heading'|trans }}</h2>
        <p class="mt-1 text-sm text-gray-600">{{ 'admin.company_settings.teams.description'|trans }}</p>

        <div class="mt-4 space-y-4">
            {% if company.isTeamsEnabled() %}
                <p class="inline-flex items-center gap-2 text-sm font-medium text-green-700">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    {{ 'admin.company_settings.teams.status.enabled'|trans }}
                </p>

                {# Save webhook URL (keep enabled) #}
                <form method="post"
                      action="{{ path('app_admin_company_settings_set_teams') }}"
                      data-testid="company-settings-teams-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_teams') }}">
                    <input type="hidden" name="enable" value="1">
                    <div>
                        <label for="teams_webhook_url" class="block text-sm font-medium text-gray-700">
                            {{ 'admin.company_settings.teams.webhook_url_label'|trans }}
                        </label>
                        <input id="teams_webhook_url"
                               type="url"
                               name="teams_webhook_url"
                               value="{{ company.teamsWebhookUrl ?? '' }}"
                               placeholder="{{ 'admin.company_settings.teams.webhook_url_placeholder'|trans }}"
                               class="mt-1 block w-full max-w-xl rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                        <p class="mt-1 text-xs text-gray-500">{{ 'admin.company_settings.teams.webhook_url_hint'|trans }}</p>
                    </div>
                    <button type="submit"
                            class="mt-3 inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                        {{ 'admin.company_settings.teams.save_button'|trans }}
                    </button>
                </form>

                {# Disable Teams (webhook URL is preserved in DB, not re-sent) #}
                <form method="post" action="{{ path('app_admin_company_settings_set_teams') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_teams') }}">
                    <input type="hidden" name="enable" value="0">
                    <button type="submit"
                            class="inline-flex items-center rounded-md border border-red-200 bg-red-50 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-100">
                        {{ 'admin.company_settings.teams.disable_button'|trans }}
                    </button>
                </form>
            {% else %}
                <p class="text-sm text-gray-500">{{ 'admin.company_settings.teams.status.disabled'|trans }}</p>

                {# Enable Teams #}
                <form method="post"
                      action="{{ path('app_admin_company_settings_set_teams') }}"
                      data-testid="company-settings-teams-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_teams') }}">
                    <input type="hidden" name="enable" value="1">
                    <div>
                        <label for="teams_webhook_url" class="block text-sm font-medium text-gray-700">
                            {{ 'admin.company_settings.teams.webhook_url_label'|trans }}
                        </label>
                        <input id="teams_webhook_url"
                               type="url"
                               name="teams_webhook_url"
                               value="{{ company.teamsWebhookUrl ?? '' }}"
                               placeholder="{{ 'admin.company_settings.teams.webhook_url_placeholder'|trans }}"
                               class="mt-1 block w-full max-w-xl rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                        <p class="mt-1 text-xs text-gray-500">{{ 'admin.company_settings.teams.webhook_url_hint'|trans }}</p>
                    </div>
                    <button type="submit"
                            class="mt-3 inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                        {{ 'admin.company_settings.teams.enable_button'|trans }}
                    </button>
                </form>
            {% endif %}
        </div>
    </section>

    {# LDAP / Active Directory #}
    <section class="rounded-xl bg-white p-6 shadow-sm" data-testid="company-settings-ldap">
        <h2 class="text-lg font-semibold text-gray-900">{{ 'admin.company_settings.ldap.heading'|trans }}</h2>
        <p class="mt-1 text-sm text-gray-600">{{ 'admin.company_settings.ldap.description'|trans }}</p>

        <div class="mt-4">
            {% if company.isLdapEnabled() %}
                <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-green-200 bg-green-50 px-3 py-1 text-sm font-medium text-green-800">
                    <span class="h-2 w-2 rounded-full bg-green-500"></span>
                    {{ 'admin.company_settings.ldap.status.enabled'|trans }}
                </div>

                {# Save config (keep enabled) #}
                <form method="post"
                      action="{{ path('app_admin_company_settings_set_ldap') }}"
                      class="mb-4"
                      data-testid="company-settings-ldap-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_ldap') }}">
                    <input type="hidden" name="enable" value="1">
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        {% include 'admin/company_settings/_ldap_fields.html.twig' with { company: company } %}
                    </div>
                    <button type="submit"
                            class="mt-4 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600">
                        {{ 'admin.company_settings.ldap.save_button'|trans }}
                    </button>
                </form>

                {# Disable (preserve current config values) #}
                <form method="post" action="{{ path('app_admin_company_settings_set_ldap') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_ldap') }}">
                    <input type="hidden" name="enable" value="0">
                    <input type="hidden" name="ldap_host" value="{{ company.ldapHost ?? '' }}">
                    <input type="hidden" name="ldap_port" value="{{ company.ldapPort ?? 389 }}">
                    <input type="hidden" name="ldap_encryption" value="{{ company.ldapEncryption ?? 'none' }}">
                    <input type="hidden" name="ldap_bind_dn" value="{{ company.ldapBindDn ?? '' }}">
                    <input type="hidden" name="ldap_base_dn" value="{{ company.ldapBaseDn ?? '' }}">
                    <input type="hidden" name="ldap_user_filter" value="{{ company.ldapUserFilter ?? '' }}">
                    <input type="hidden" name="ldap_group_manager_dn" value="{{ company.ldapGroupManagerDn ?? '' }}">
                    <input type="hidden" name="ldap_group_admin_dn" value="{{ company.ldapGroupAdminDn ?? '' }}">
                    <button type="submit"
                            class="rounded-lg border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100 focus:outline-none focus:ring-2 focus:ring-red-400">
                        {{ 'admin.company_settings.ldap.disable_button'|trans }}
                    </button>
                </form>
            {% else %}
                <p class="text-sm text-gray-500">{{ 'admin.company_settings.ldap.status.disabled'|trans }}</p>
                <form method="post"
                      action="{{ path('app_admin_company_settings_set_ldap') }}"
                      class="mt-4"
                      data-testid="company-settings-ldap-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('company_settings_ldap') }}">
                    <input type="hidden" name="enable" value="1">
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        {% include 'admin/company_settings/_ldap_fields.html.twig' with { company: company } %}
                    </div>
                    <button type="submit"
                            class="mt-4 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600">
                        {{ 'admin.company_settings.ldap.enable_button'|trans }}
                    </button>
                </form>
            {% endif %}
        </div>
    </section>

</div>
{% endblock %}
