{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.entitlements.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-7xl p-6">
    <header class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">{{ 'admin.entitlements.heading'|trans }}</h1>
            <p class="mt-1 max-w-3xl text-sm text-gray-500">{{ 'admin.entitlements.description'|trans }}</p>
        </div>
        <div class="flex flex-wrap items-end gap-3">
            <form method="get"
                  action="{{ path('app_admin_entitlement_index') }}"
                  class="flex items-end gap-2"
                  data-testid="admin-entitlements-year-form">
                <div>
                    <label for="admin-entitlements-year" class="block text-xs font-medium text-gray-500">
                        {{ 'admin.entitlements.filter.year_label'|trans }}
                    </label>
                    {# Merge currentYear into the option list so the default is
                       always offered, even on a fresh tenant with no records yet. #}
                    {% set yearOptions = availableYears %}
                    {% if currentYear not in yearOptions %}
                        {% set yearOptions = [currentYear]|merge(yearOptions)|sort|reverse %}
                    {% endif %}
                    <select id="admin-entitlements-year"
                            name="year"
                            onchange="this.form.requestSubmit()"
                            class="mt-1 block w-32 rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
                            data-testid="admin-entitlements-year-select">
                        {% for y in yearOptions %}
                            <option value="{{ y }}" {{ selectedYear == y ? 'selected' : '' }}>{{ y }}</option>
                        {% endfor %}
                        <option value="all" {{ selectedYear is null ? 'selected' : '' }}>
                            {{ 'admin.entitlements.filter.all_years'|trans }}
                        </option>
                    </select>
                </div>
                <noscript>
                    <button type="submit" class="rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700">
                        {{ 'admin.entitlements.filter.apply'|trans }}
                    </button>
                </noscript>
            </form>
            <a href="{{ path('app_dashboard') }}"
               class="inline-flex items-center gap-1 whitespace-nowrap rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                {{ 'nav.home'|trans }}
            </a>
            <a href="{{ path('app_admin_entitlement_new') }}"
               class="whitespace-nowrap rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                {{ 'admin.entitlements.create'|trans }}
            </a>
        </div>
    </header>

    <div class="overflow-hidden rounded-xl bg-white shadow-sm">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr class="text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
                    <th class="px-6 py-3">{{ 'admin.entitlements.field.employee'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.entitlements.field.year'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.entitlements.field.type'|trans }}</th>
                    <th class="px-6 py-3 text-right">{{ 'admin.entitlements.field.granted'|trans }}</th>
                    <th class="px-6 py-3 text-right">{{ 'admin.entitlements.field.used'|trans }}</th>
                    <th class="px-6 py-3 text-right">{{ 'admin.entitlements.field.remaining'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.entitlements.field.expires_at'|trans }}</th>
                    <th class="px-6 py-3 text-right"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white text-sm text-gray-700">
                {% set previous_employee_id = null %}
                {% for entry in entries %}
                    {% set is_expired = entry.expiresAt is not null and today > entry.expiresAt %}
                    {% set is_new_employee = previous_employee_id != entry.employee.id %}
                    <tr data-testid="entitlement-row-{{ entry.id }}"
                        class="{{ is_new_employee ? 'border-t-2 border-gray-300' : '' }}">
                        <td class="px-6 py-3 whitespace-nowrap {{ is_new_employee ? 'font-medium text-gray-900' : 'text-gray-400' }}">
                            {{ is_new_employee ? entry.employee.fullName : '' }}
                        </td>
                        <td class="px-6 py-3">{{ entry.year }}</td>
                        <td class="px-6 py-3">
                            <div>{{ ('admin.entitlements.type.' ~ entry.type.value)|trans }}</div>
                            {% if entry.type.value == 'carryover' %}
                                <div class="text-xs text-gray-500" data-testid="entitlement-source-year-{{ entry.id }}">
                                    {{ 'admin.entitlements.from_year'|trans({ '%year%': entry.year - 1 }) }}
                                </div>
                            {% endif %}
                        </td>
                        <td class="px-6 py-3 text-right font-mono">{{ entry.hoursGranted|number_format(2, ',', '.') }}</td>
                        <td class="px-6 py-3 text-right font-mono">{{ entry.hoursUsed|number_format(2, ',', '.') }}</td>
                        <td class="px-6 py-3 text-right font-mono">{{ entry.hoursRemaining|number_format(2, ',', '.') }}</td>
                        <td class="px-6 py-3 {{ is_expired ? 'text-rose-600 font-semibold' : '' }}">
                            {% if entry.expiresAt %}
                                {{ entry.expiresAt|date('d.m.Y') }}
                                {% if is_expired %}
                                    <span class="ml-1 inline-flex items-center rounded-md bg-rose-50 px-1.5 py-0.5 text-xs font-medium text-rose-700">
                                        {{ 'admin.entitlements.expired_badge'|trans }}
                                    </span>
                                {% endif %}
                            {% else %}
                                <span class="text-gray-400">{{ 'admin.entitlements.no_expiry'|trans }}</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-3 text-right">
                            <div class="flex items-center justify-end gap-2">
                                {% if entry.type.value == 'carryover' %}
                                    <a href="{{ path('app_admin_entitlement_edit_expiry', { id: entry.id }) }}"
                                       class="inline-flex items-center whitespace-nowrap rounded-md border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-medium text-blue-700 hover:bg-blue-100">
                                        {{ 'admin.entitlements.edit_expiry'|trans }}
                                    </a>
                                {% endif %}

                                <a href="{{ path('app_admin_entitlement_edit', { id: entry.id }) }}"
                                   class="inline-flex items-center whitespace-nowrap rounded-md border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-medium text-blue-700 hover:bg-blue-100"
                                   data-testid="entitlement-edit-{{ entry.id }}">
                                    {{ 'admin.entitlements.edit'|trans }}
                                </a>

                                <form method="post"
                                      action="{{ path('app_admin_entitlement_delete', { id: entry.id }) }}"
                                      data-testid="entitlement-delete-form-{{ entry.id }}"
                                      data-turbo-confirm="{{ 'admin.entitlements.delete.confirm'|trans }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('entitlement-delete-' ~ entry.id) }}">
                                    <button type="submit"
                                            class="inline-flex items-center whitespace-nowrap rounded-md border border-rose-200 bg-rose-50 px-3 py-1.5 text-xs font-medium text-rose-700 hover:bg-rose-100"
                                            data-testid="entitlement-delete-{{ entry.id }}">
                                        {{ 'admin.entitlements.delete.button'|trans }}
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% set previous_employee_id = entry.employee.id %}
                {% else %}
                    <tr>
                        <td colspan="8" class="px-6 py-6 text-center text-gray-500">{{ 'admin.entitlements.empty'|trans }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
