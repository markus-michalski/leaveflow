{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.entitlements.new.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-xl p-6">
    <header class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-semibold text-gray-900">
            {{ 'admin.entitlements.new.title'|trans }}
        </h1>
        <a href="{{ path('app_admin_entitlement_index') }}"
           class="inline-flex items-center gap-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
            {{ 'nav.back_to_list'|trans }}
        </a>
    </header>

    <div class="rounded-xl bg-white p-6 shadow-sm">
        {{ form_start(form, { attr: {
            class: 'space-y-4',
            'data-testid': 'admin-entitlement-form',
            'data-controller': 'entitlement-hint',
            'data-entitlement-hint-base-url-value': path('app_admin_entitlement_pro_rata_hint')
        } }) }}
            <p class="text-xs text-gray-500">{{ 'form.required_legend'|trans }}</p>
            <p class="rounded-md bg-blue-50 p-3 text-xs text-blue-800">{{ 'admin.entitlements.new.hint'|trans }}</p>

            {% include 'admin/entitlements/_pro_rata_hint.html.twig' with { proRataHint: proRataHint } %}

            {{ form_errors(form) }}

            {{ form_row(form.employee, {
                label_attr: { class: 'block text-sm font-medium text-gray-700' },
                attr: {
                    class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2',
                    'data-entitlement-hint-target': 'employee',
                    'data-action': 'change->entitlement-hint#reload'
                }
            }) }}

            <div class="grid grid-cols-2 gap-4">
                {{ form_row(form.year, {
                    label_attr: { class: 'block text-sm font-medium text-gray-700' },
                    attr: {
                        class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2',
                        'data-entitlement-hint-target': 'year',
                        'data-action': 'change->entitlement-hint#reload'
                    }
                }) }}
                {{ form_row(form.type, {
                    label_attr: { class: 'block text-sm font-medium text-gray-700' },
                    attr: {
                        class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2',
                        'data-entitlement-hint-target': 'type',
                        'data-action': 'change->entitlement-hint#reload'
                    }
                }) }}
            </div>

            {{ form_row(form.hoursGranted, { label_attr: { class: 'block text-sm font-medium text-gray-700' }, attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' } }) }}

            {{ form_row(form.expiresAt, { label_attr: { class: 'block text-sm font-medium text-gray-700' }, attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' } }) }}

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_admin_entitlement_index') }}"
                   class="inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                    {{ 'form.cancel'|trans }}
                </a>
                <button type="submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                    {{ 'form.create'|trans }}
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
