{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.api_tokens.create'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-2xl p-6">
    <header class="mb-6">
        <h1 class="text-2xl font-semibold text-gray-900">{{ 'admin.api_tokens.create'|trans }}</h1>
        <p class="mt-1 text-sm text-gray-500">{{ 'admin.api_tokens.create_description'|trans }}</p>
    </header>

    {{ form_start(form, { attr: { class: 'space-y-5' } }) }}

        <div>
            {{ form_label(form.name, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.name, { attr: { class: 'block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500' } }) }}
            {{ form_errors(form.name) }}
        </div>

        <div>
            {{ form_label(form.expiresAt, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            <p class="mb-1 text-xs text-gray-500">{{ 'admin.api_tokens.field.expires_at_hint'|trans }}</p>
            {{ form_widget(form.expiresAt, { attr: { class: 'block rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500' } }) }}
            {{ form_errors(form.expiresAt) }}
        </div>

        <div class="flex items-center justify-between pt-2">
            <a href="{{ path('app_admin_api_token_index') }}"
               class="text-sm text-gray-600 hover:text-gray-900">
                {{ 'admin.api_tokens.cancel'|trans }}
            </a>
            <button type="submit"
                    class="rounded-md bg-blue-600 px-5 py-2 text-sm font-medium text-white hover:bg-blue-700">
                {{ 'admin.api_tokens.generate'|trans }}
            </button>
        </div>

    {{ form_end(form) }}
</div>
{% endblock %}
