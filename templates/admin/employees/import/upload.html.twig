{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.employees.import.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl p-6">
    <header class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <h1 class="text-2xl font-semibold text-gray-900">{{ 'admin.employees.import.heading'|trans }}</h1>
        <a href="{{ path('app_admin_employee_index') }}"
           class="inline-flex items-center gap-1 whitespace-nowrap rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
            {{ 'nav.back_to_list'|trans }}
        </a>
    </header>

    <section class="mb-6 rounded-xl bg-blue-50 p-6 text-sm text-blue-900">
        <p class="font-medium">{{ 'admin.employees.import.intro_heading'|trans }}</p>
        <p class="mt-2">{{ 'admin.employees.import.intro_body'|trans|raw }}</p>
        <p class="mt-3">
            <a href="{{ path('app_admin_employee_import_template') }}"
               class="inline-flex items-center gap-1 rounded-md border border-blue-300 bg-white px-3 py-2 text-sm font-medium text-blue-700 hover:bg-blue-100"
               data-testid="employee-import-template-download">
                {{ 'admin.employees.import.download_template'|trans }}
            </a>
        </p>
    </section>

    <div class="rounded-xl bg-white p-6 shadow-sm">
        {{ form_start(form, { attr: { class: 'space-y-4', 'data-testid': 'employee-import-upload-form', 'data-turbo': 'false', enctype: 'multipart/form-data' }, action: path('app_admin_employee_import_preview') }) }}
            {{ form_errors(form) }}
            {{ form_row(form.file, {
                label_attr: { class: 'block text-sm font-medium text-gray-700' },
                attr: { class: 'mt-1 block w-full text-sm text-gray-700 file:mr-3 file:rounded-md file:border-0 file:bg-blue-50 file:px-3 file:py-2 file:text-sm file:font-medium file:text-blue-700 hover:file:bg-blue-100' }
            }) }}

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_admin_employee_index') }}"
                   class="inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                    {{ 'form.cancel'|trans }}
                </a>
                <button type="submit"
                        class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
                        data-testid="employee-import-upload-submit">
                    {{ 'admin.employees.import.preview'|trans }}
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
