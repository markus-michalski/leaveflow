{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.employees.leave_requests.title'|trans({ '%name%': employee.fullName }) }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-7xl p-6">
    <header class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">
                {{ 'admin.employees.leave_requests.heading'|trans({ '%name%': employee.fullName }) }}
            </h1>
            <p class="mt-1 text-xs text-gray-500">
                {{ employee.employeeNumber }} · {{ employee.location.name }}
                {% if employee.department %}
                    · {{ employee.department.name }}
                {% endif %}
            </p>
        </div>
        <div class="flex items-center gap-3">
            <a href="{{ path('app_admin_employee_index') }}"
               class="inline-flex items-center gap-1 whitespace-nowrap rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                {{ 'nav.back_to_list'|trans }}
            </a>
        </div>
    </header>

    {% if yearAggregates is empty %}
        <div class="rounded-xl bg-white p-12 text-center shadow-sm" data-testid="employee-leave-requests-empty">
            <p class="text-sm text-gray-500">{{ 'admin.employees.leave_requests.empty'|trans }}</p>
        </div>
    {% else %}
        <section class="mb-6 rounded-xl bg-white p-6 shadow-sm">
            <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-500">
                {{ 'admin.employees.leave_requests.summary_heading'|trans }}
            </h2>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {% for year, perType in yearAggregates %}
                    <div class="rounded-lg border border-gray-200 p-4" data-testid="leave-summary-{{ year }}">
                        <h3 class="text-sm font-semibold text-gray-900">{{ year }}</h3>
                        <dl class="mt-2 space-y-1 text-sm">
                            {% for typeName, hours in perType %}
                                <div class="flex items-center justify-between gap-3">
                                    <dt class="text-gray-600">{{ typeName }}</dt>
                                    <dd class="font-mono text-gray-900">{{ hours|number_format(2, ',', '.') }} h</dd>
                                </div>
                            {% endfor %}
                        </dl>
                    </div>
                {% endfor %}
            </div>
        </section>

        <form method="get"
              action="{{ path('app_admin_employee_leave_requests', { id: employee.id }) }}"
              class="mb-4 flex items-end gap-3"
              data-testid="employee-leave-requests-filter-form">
            <div>
                <label for="employee-leave-year" class="block text-xs font-medium text-gray-500">
                    {{ 'admin.employees.leave_requests.filter.year_label'|trans }}
                </label>
                <select id="employee-leave-year"
                        name="year"
                        onchange="this.form.requestSubmit()"
                        class="mt-1 block w-32 rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
                        data-testid="employee-leave-year-select">
                    <option value="" {{ selectedYear is null ? 'selected' : '' }}>
                        {{ 'admin.employees.leave_requests.filter.all_years'|trans }}
                    </option>
                    {% for y in availableYears %}
                        <option value="{{ y }}" {{ selectedYear == y ? 'selected' : '' }}>{{ y }}</option>
                    {% endfor %}
                </select>
            </div>
            <noscript>
                <button type="submit" class="rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700">
                    {{ 'admin.employees.leave_requests.filter.apply'|trans }}
                </button>
            </noscript>
        </form>

        <div class="overflow-hidden rounded-xl bg-white shadow-sm">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr class="text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
                        <th class="px-6 py-3">{{ 'my.leave_requests.field.range'|trans }}</th>
                        <th class="px-6 py-3">{{ 'my.leave_requests.field.absence_type'|trans }}</th>
                        <th class="px-6 py-3 text-right">{{ 'my.leave_requests.field.hours'|trans }}</th>
                        <th class="px-6 py-3">{{ 'my.leave_requests.field.status'|trans }}</th>
                        <th class="px-6 py-3">{{ 'my.leave_requests.field.requested_at'|trans }}</th>
                        <th class="px-6 py-3 text-right"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 bg-white text-sm text-gray-700">
                    {% for req in requests %}
                        <tr data-testid="employee-leave-request-row-{{ req.id }}">
                            <td class="px-6 py-3 whitespace-nowrap">
                                {{ req.startDate|date('d.m.Y') }}
                                {% if req.startDate != req.endDate %}
                                    – {{ req.endDate|date('d.m.Y') }}
                                {% endif %}
                            </td>
                            <td class="px-6 py-3">
                                <span class="inline-flex items-center gap-1">
                                    <span class="inline-block h-2.5 w-2.5 rounded-full" style="background-color: {{ req.absenceType.color }}"></span>
                                    {{ req.absenceType.name }}
                                </span>
                            </td>
                            <td class="px-6 py-3 text-right font-mono">{{ req.totalHours|number_format(2, ',', '.') }}</td>
                            <td class="px-6 py-3">
                                {% set status_classes = {
                                    'pending': 'bg-amber-100 text-amber-800',
                                    'cancel_requested': 'bg-orange-100 text-orange-800',
                                    'approved': 'bg-green-100 text-green-800',
                                    'rejected': 'bg-rose-100 text-rose-800',
                                    'cancelled': 'bg-gray-100 text-gray-700',
                                    'recorded': 'bg-sky-100 text-sky-800',
                                } %}
                                <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium {{ status_classes[req.status.value]|default('bg-gray-100 text-gray-700') }}">
                                    {{ ('my.leave_requests.status.' ~ req.status.value)|trans }}
                                </span>
                            </td>
                            <td class="px-6 py-3 whitespace-nowrap text-gray-500">{{ req.requestedAt|date('d.m.Y H:i') }}</td>
                            <td class="px-6 py-3 text-right">
                                <a href="{{ path('app_admin_leave_request_show', { id: req.id }) }}"
                                   class="inline-flex items-center whitespace-nowrap rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 hover:bg-gray-50">
                                    {{ 'admin.leave_requests.show.heading'|trans }}
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-6 text-center text-gray-500" data-testid="employee-leave-requests-filter-empty">
                                {{ 'admin.employees.leave_requests.no_match'|trans }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
