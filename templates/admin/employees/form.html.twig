{% extends 'base.html.twig' %}

{% block title %}{{ (is_new ? 'admin.employees.create' : 'admin.employees.edit')|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-2xl p-6">
    <header class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-semibold text-gray-900">
            {{ (is_new ? 'admin.employees.create' : 'admin.employees.edit_heading')|trans }}
        </h1>
        <a href="{{ path('app_admin_employee_index') }}"
           class="inline-flex items-center gap-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
            {{ 'admin.employees.back'|trans }}
        </a>
    </header>

    <div class="rounded-xl bg-white p-6 shadow-sm">
        {{ form_start(form, { attr: { class: 'space-y-4', 'data-testid': 'admin-employee-form' } }) }}
            <p class="text-xs text-gray-500">{{ 'form.required_legend'|trans }}</p>
            {% if form.vars.errors|length > 0 %}
                <div class="rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-800">
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            {{ form_row(form.fullName, { label_attr: { class: 'block text-sm font-medium text-gray-700' }, attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' } }) }}
            {{ form_row(form.employeeNumber, { label_attr: { class: 'block text-sm font-medium text-gray-700' }, attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' } }) }}
            {{ form_row(form.location, { label_attr: { class: 'block text-sm font-medium text-gray-700' }, attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' } }) }}
            {{ form_row(form.department, { label_attr: { class: 'block text-sm font-medium text-gray-700' }, attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' } }) }}

            <div class="rounded-md border border-gray-200 p-4 space-y-4 bg-gray-50"
                 data-controller="schedule-distribution"
                 data-schedule-distribution-mode-value="{{ form.distributionMode.vars.value|default('auto') }}">
                <h2 class="text-sm font-semibold text-gray-700">{{ 'admin.employees.schedule'|trans }}</h2>
                {{ form_row(form.weeklyHours, {
                    label_attr: { class: 'block text-sm font-medium text-gray-700' },
                    attr: {
                        class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2',
                        'data-schedule-distribution-target': 'weeklyHours',
                        'data-action': 'input->schedule-distribution#updateSum',
                    }
                }) }}

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">{{ form.distributionMode.vars.label|trans }}</label>
                    <div class="inline-flex rounded-md border border-gray-300 bg-white p-1 text-sm">
                        {% for child in form.distributionMode %}
                            <label class="inline-flex items-center gap-2 cursor-pointer rounded px-3 py-1 hover:bg-gray-100"
                                   data-schedule-distribution-target="modeLabel"
                                   data-mode="{{ child.vars.value }}">
                                {{ form_widget(child, { attr: { class: 'sr-only', 'data-action': 'change->schedule-distribution#switchMode' } }) }}
                                <span>{{ child.vars.label|trans }}</span>
                            </label>
                        {% endfor %}
                    </div>
                </div>

                <div data-schedule-distribution-target="autoBlock">
                    <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'admin.employees.working_days'|trans }}</label>
                    <div class="flex flex-wrap gap-3">
                        {% for child in form.workingDays %}
                            <label class="inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
                                {{ form_widget(child) }}
                                <span>{{ child.vars.label|trans }}</span>
                            </label>
                        {% endfor %}
                    </div>
                </div>

                <div data-schedule-distribution-target="manualBlock" class="hidden">
                    <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'admin.employees.distribution_per_day'|trans }}</label>
                    <p class="mb-2 text-xs text-gray-500">{{ 'admin.employees.distribution_per_day_help'|trans }}</p>
                    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4 md:grid-cols-7">
                        {% for fieldName in ['hoursMonday', 'hoursTuesday', 'hoursWednesday', 'hoursThursday', 'hoursFriday', 'hoursSaturday', 'hoursSunday'] %}
                            <label class="block">
                                <span class="block text-xs font-medium text-gray-600">{{ attribute(form, fieldName).vars.label|trans }}</span>
                                {{ form_widget(attribute(form, fieldName), {
                                    attr: {
                                        class: 'mt-1 block w-full rounded-md border border-gray-300 px-2 py-1 text-sm',
                                        'data-schedule-distribution-target': 'hoursInput',
                                        'data-action': 'input->schedule-distribution#updateSum',
                                    }
                                }) }}
                            </label>
                        {% endfor %}
                    </div>
                    <p class="mt-2 text-xs"
                       data-schedule-distribution-target="sumIndicator">
                        <span data-schedule-distribution-target="sumText"></span>
                    </p>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                {{ form_row(form.joinedAt, { label_attr: { class: 'block text-sm font-medium text-gray-700' }, attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' } }) }}
                {{ form_row(form.leftAt, { label_attr: { class: 'block text-sm font-medium text-gray-700' }, attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' } }) }}
            </div>
            {% if proRataHint %}
            <div class="rounded-md bg-amber-50 border border-amber-200 p-3 text-xs text-amber-800 space-y-1">
                <p>{{ 'admin.employees.pro_rata_reminder'|trans({
                    '%joinedAt%': proRataHint.joinedAt|date('d.m.Y'),
                    '%effectiveMonths%': proRataHint.effectiveMonths,
                    '%year%': proRataHint.year
                }) }}</p>
                {% if proRataHint.probation %}
                <p class="font-medium">{{ 'admin.employees.probation_hint'|trans({'%months%': proRataHint.effectiveMonths}) }}</p>
                {% endif %}
            </div>
            {% endif %}

            {{ form_row(form.user, { label_attr: { class: 'block text-sm font-medium text-gray-700' }, attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' } }) }}

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_admin_employee_index') }}"
                   class="inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                    {{ 'admin.employees.back'|trans }}
                </a>
                <button type="submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                    {{ 'admin.employees.save'|trans }}
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
