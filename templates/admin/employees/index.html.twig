{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.employees.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-7xl p-6">
    <header class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-semibold text-gray-900">{{ 'admin.employees.heading'|trans }}</h1>
        <div class="flex items-center gap-3">
            <a href="{{ path('app_dashboard') }}"
               class="inline-flex items-center gap-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                {{ 'nav.home'|trans }}
            </a>
            <a href="{{ path('app_admin_employee_new') }}"
               class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                {{ 'admin.employees.create'|trans }}
            </a>
        </div>
    </header>

    <div class="overflow-hidden rounded-xl bg-white shadow-sm">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr class="text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
                    <th class="px-6 py-3">{{ 'admin.employees.full_name'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.employees.employee_number'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.employees.location'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.employees.schedule'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.employees.period'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.employees.linked_user'|trans }}</th>
                    <th class="px-6 py-3 text-right">{{ 'admin.employees.actions'|trans }}</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white text-sm text-gray-700">
                {% for employee in employees %}
                    <tr data-testid="employee-row-{{ employee.id }}">
                        <td class="px-6 py-3 font-medium text-gray-900">{{ employee.fullName }}</td>
                        <td class="px-6 py-3"><code class="rounded bg-gray-100 px-1 py-0.5 text-xs">{{ employee.employeeNumber }}</code></td>
                        <td class="px-6 py-3">{{ employee.location.name }}</td>
                        <td class="px-6 py-3">
                            {{ employee.workSchedule.weeklyHours }}h / {{ employee.workSchedule.workingDays|length }}{{ 'admin.employees.days_suffix'|trans }}
                        </td>
                        <td class="px-6 py-3 text-xs">
                            {{ employee.joinedAt|date('Y-m-d') }}
                            {% if employee.leftAt %}
                                → {{ employee.leftAt|date('Y-m-d') }}
                            {% endif %}
                        </td>
                        <td class="px-6 py-3">
                            {% if employee.user %}
                                <span class="text-blue-700">{{ employee.user.email }}</span>
                            {% else %}
                                <span class="text-gray-400">{{ 'admin.employees.no_user'|trans }}</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-3 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="{{ path('app_admin_employee_leave_requests', { id: employee.id }) }}"
                                   class="inline-flex items-center whitespace-nowrap rounded-md border border-gray-200 bg-white px-3 py-2 text-xs font-medium text-gray-700 hover:bg-gray-50"
                                   data-testid="admin-employee-leave-requests-link-{{ employee.id }}">
                                    {{ 'admin.employees.leave_requests.button'|trans }}
                                </a>
                                <a href="{{ path('app_admin_employee_edit', { id: employee.id }) }}"
                                   class="inline-flex items-center whitespace-nowrap rounded-md border border-blue-200 bg-blue-50 px-3 py-2 text-xs font-medium text-blue-700 hover:bg-blue-100">
                                    {{ 'admin.employees.edit'|trans }}
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="px-6 py-6 text-center text-gray-500">{{ 'admin.employees.empty'|trans }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
