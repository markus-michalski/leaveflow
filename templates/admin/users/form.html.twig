{% extends 'base.html.twig' %}

{% block title %}{{ (is_new ? 'admin.users.create' : 'admin.users.edit')|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-xl p-6">
    <header class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-semibold text-gray-900">
            {{ (is_new ? 'admin.users.create' : 'admin.users.edit_heading')|trans }}
        </h1>
        <a href="{{ path('app_admin_user_index') }}" class="text-sm text-gray-600 hover:underline">
            {{ 'nav.admin.users'|trans }}
        </a>
    </header>

    <div class="rounded-xl bg-white p-6 shadow-sm">
        {{ form_start(form, { attr: { class: 'space-y-4', 'data-testid': 'admin-user-form' } }) }}
            {% if form.email is defined %}
                {{ form_row(form.email, {
                    label_attr: { class: 'block text-sm font-medium text-gray-700' },
                    attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' }
                }) }}
            {% endif %}

            {{ form_row(form.role, {
                label_attr: { class: 'block text-sm font-medium text-gray-700' },
                attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' }
            }) }}

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_admin_user_index') }}" class="text-sm text-gray-600 hover:underline">
                    {{ 'nav.admin.users'|trans }}
                </a>
                <button type="submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                    {{ 'admin.users.save'|trans }}
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
