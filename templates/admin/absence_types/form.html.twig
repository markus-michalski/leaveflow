{% extends 'base.html.twig' %}

{% block title %}{{ (is_new ? 'admin.absence_types.new.title' : 'admin.absence_types.edit_view.title')|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-xl p-6">
    <header class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-semibold text-gray-900">
            {{ (is_new ? 'admin.absence_types.new.title' : 'admin.absence_types.edit_view.title')|trans }}
        </h1>
        <a href="{{ path('app_admin_absence_type_index') }}"
           class="inline-flex items-center gap-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
            {{ 'nav.back_to_list'|trans }}
        </a>
    </header>

    <div class="rounded-xl bg-white p-6 shadow-sm">
        {{ form_start(form, { attr: { class: 'space-y-4', 'data-testid': 'admin-absence-type-form' } }) }}
            <p class="text-xs text-gray-500">{{ 'form.required_legend'|trans }}</p>
            {{ form_errors(form) }}
            {{ form_row(form.name, { label_attr: { class: 'block text-sm font-medium text-gray-700' }, attr: { class: 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2' } }) }}

            <div class="flex items-end gap-3">
                <div class="flex-1">
                    {{ form_row(form.color, { label_attr: { class: 'block text-sm font-medium text-gray-700' }, attr: { class: 'mt-1 block h-10 w-full rounded-md border border-gray-300 px-2 py-1' } }) }}
                </div>
                <span class="mb-2 inline-block h-10 w-10 rounded-md border border-gray-200"
                      style="background-color: {{ form.color.vars.value|default('#3B82F6') }};"></span>
            </div>

            <div class="space-y-3 rounded-md border border-gray-200 bg-gray-50 p-4">
                {% for field in [form.deductsFromLeave, form.requiresApproval, form.active] %}
                    <label class="flex cursor-pointer items-center gap-3 text-sm text-gray-700">
                        {{ form_widget(field, { attr: { class: 'h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500' } }) }}
                        <span>{{ field.vars.label|trans }}</span>
                    </label>
                {% endfor %}
            </div>

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_admin_absence_type_index') }}"
                   class="inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                    {{ 'form.cancel'|trans }}
                </a>
                <button type="submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                    {{ (is_new ? 'form.create' : 'form.save')|trans }}
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
