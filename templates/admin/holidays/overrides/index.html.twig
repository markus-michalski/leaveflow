{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.holidays.override.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-6xl p-6">
    <header class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">{{ 'admin.holidays.override.heading'|trans }}</h1>
            <p class="mt-1 max-w-3xl text-xs text-gray-500">{{ 'admin.holidays.override.description'|trans }}</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="{{ path('app_admin_holiday_index') }}"
               class="inline-flex items-center gap-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                {{ 'admin.holidays.override.back'|trans }}
            </a>
            <a href="{{ path('app_admin_holiday_override_new') }}"
               class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                {{ 'admin.holidays.override.create'|trans }}
            </a>
        </div>
    </header>

    <div class="overflow-hidden rounded-xl bg-white shadow-sm">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr class="text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
                    <th class="px-6 py-3">{{ 'admin.holidays.override.date'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.holidays.override.federal_state'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.holidays.override.location'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.holidays.override.name'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.holidays.override.type'|trans }}</th>
                    <th class="px-6 py-3 text-right">{{ 'admin.holidays.actions'|trans }}</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white text-sm text-gray-700">
                {% for override in overrides %}
                    <tr data-testid="override-row-{{ override.id }}">
                        <td class="px-6 py-3 font-medium text-gray-900">{{ override.date|date('d.m.Y') }}</td>
                        <td class="px-6 py-3"><code class="rounded bg-gray-100 px-1 py-0.5 text-xs">{{ override.federalState.value }}</code> {{ override.federalState.label|trans }}</td>
                        <td class="px-6 py-3">
                            {% if override.location %}
                                {{ override.location.name }}
                            {% else %}
                                <span class="text-xs text-gray-400">{{ 'admin.holidays.override.location_all'|trans }}</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-3">{{ override.name }}</td>
                        <td class="px-6 py-3">
                            {% if override.type.value == 'added' %}
                                <span class="inline-flex rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-800">{{ override.type.label|trans }}</span>
                            {% else %}
                                <span class="inline-flex rounded-full bg-rose-100 px-2 py-0.5 text-xs font-medium text-rose-800">{{ override.type.label|trans }}</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-3 text-right">
                            <div class="inline-flex items-center gap-2">
                                <a href="{{ path('app_admin_holiday_override_edit', { id: override.id }) }}"
                                   class="inline-flex items-center rounded-md border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-medium text-blue-700 hover:bg-blue-100">
                                    {{ 'admin.holidays.override.edit'|trans }}
                                </a>
                                <form method="post" action="{{ path('app_admin_holiday_override_delete', { id: override.id }) }}"
                                      onsubmit="return confirm('{{ 'admin.holidays.override.confirm_delete'|trans }}');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete-override-' ~ override.id) }}">
                                    <button type="submit" class="inline-flex items-center rounded-md border border-rose-200 bg-rose-50 px-3 py-1.5 text-xs font-medium text-rose-700 hover:bg-rose-100">
                                        {{ 'admin.holidays.override.delete'|trans }}
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="px-6 py-6 text-center text-gray-500">{{ 'admin.holidays.override.empty'|trans }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
