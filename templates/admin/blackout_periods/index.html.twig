{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.blackout_periods.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-6xl p-6">
    <header class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">{{ 'admin.blackout_periods.heading'|trans }}</h1>
            <p class="mt-1 max-w-3xl text-sm text-gray-500">{{ 'admin.blackout_periods.description'|trans }}</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="{{ path('app_admin_blackout_period_new') }}"
               class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
               data-testid="blackout-period-create-link">
                {{ 'admin.blackout_periods.create'|trans }}
            </a>
        </div>
    </header>

    <div class="overflow-hidden rounded-xl bg-white shadow-sm">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr class="text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
                    <th class="px-6 py-3">{{ 'admin.blackout_periods.start_date'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.blackout_periods.end_date'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.blackout_periods.reason'|trans }}</th>
                    <th class="px-6 py-3">{{ 'admin.blackout_periods.scope'|trans }}</th>
                    <th class="px-6 py-3 text-right">{{ 'admin.blackout_periods.actions'|trans }}</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white text-sm text-gray-700">
                {% for period in periods %}
                    <tr data-testid="blackout-period-row-{{ period.id }}">
                        <td class="px-6 py-3 font-medium text-gray-900">{{ period.startDate|date('d.m.Y') }}</td>
                        <td class="px-6 py-3 font-medium text-gray-900">{{ period.endDate|date('d.m.Y') }}</td>
                        <td class="px-6 py-3">{{ period.reason }}</td>
                        <td class="px-6 py-3">
                            {% if period.department %}
                                <span class="inline-flex items-center rounded-full bg-amber-50 px-2 py-1 text-xs font-medium text-amber-800">
                                    {{ period.department.name }}
                                </span>
                            {% else %}
                                <span class="inline-flex items-center rounded-full bg-rose-50 px-2 py-1 text-xs font-medium text-rose-800">
                                    {{ 'admin.blackout_periods.scope_company_wide'|trans }}
                                </span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-3 text-right">
                            <div class="inline-flex items-center gap-2">
                                <a href="{{ path('app_admin_blackout_period_edit', { id: period.id }) }}"
                                   class="inline-flex items-center rounded-md border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-medium text-blue-700 hover:bg-blue-100">
                                    {{ 'admin.blackout_periods.edit'|trans }}
                                </a>
                                <form method="post" action="{{ path('app_admin_blackout_period_delete', { id: period.id }) }}"
                                      onsubmit="return confirm('{{ 'admin.blackout_periods.confirm_delete'|trans }}');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete-blackout-period-' ~ period.id) }}">
                                    <button type="submit" class="inline-flex items-center rounded-md border border-rose-200 bg-rose-50 px-3 py-1.5 text-xs font-medium text-rose-700 hover:bg-rose-100">
                                        {{ 'admin.blackout_periods.delete'|trans }}
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="px-6 py-6 text-center text-gray-500" data-testid="blackout-periods-empty">
                            {{ 'admin.blackout_periods.empty'|trans }}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
