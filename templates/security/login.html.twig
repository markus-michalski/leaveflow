{% extends 'base.html.twig' %}

{% block title %}{{ 'security.login.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block app_header %}{% endblock %}

{% block body %}
<div class="flex min-h-screen items-center justify-center bg-gray-50 px-4">
    <div class="w-full max-w-md space-y-6 rounded-xl bg-white p-8 shadow-sm">
        <div class="text-center">
            {% if company_logo_path %}
                <img src="{{ asset(company_logo_path) }}"
                     alt="{{ company_name ?? ('app.name'|trans) }}"
                     class="mx-auto mb-3 h-10 w-auto">
            {% endif %}
            <h1 class="text-2xl font-semibold text-gray-900">{{ 'security.login.heading'|trans }}</h1>
            {% if not company_logo_path %}
                <p class="mt-1 text-sm text-gray-500">{{ 'app.name'|trans }}</p>
            {% endif %}
        </div>

        {% if error %}
            <div class="rounded-md bg-red-50 p-3 text-sm text-red-800" role="alert">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" class="space-y-4" data-testid="login-form">
            <div>
                <label for="inputEmail" class="block text-sm font-medium text-gray-700">
                    {{ 'security.login.email'|trans }}
                </label>
                <input
                    type="email"
                    id="inputEmail"
                    name="_username"
                    value="{{ last_username }}"
                    autocomplete="email"
                    required
                    autofocus
                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 focus:border-blue-500 focus:ring-blue-500"
                >
            </div>

            <div>
                <label for="inputPassword" class="block text-sm font-medium text-gray-700">
                    {{ 'security.login.password'|trans }}
                </label>
                <input
                    type="password"
                    id="inputPassword"
                    name="_password"
                    autocomplete="current-password"
                    required
                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 focus:border-blue-500 focus:ring-blue-500"
                >
            </div>

            <div class="flex items-center justify-between text-sm">
                <label class="inline-flex items-center gap-2 text-gray-700">
                    <input type="checkbox" name="_remember_me" class="rounded border-gray-300">
                    {{ 'security.login.remember_me'|trans }}
                </label>
                <a href="{{ path('app_forgot_password_request') }}" class="text-blue-600 hover:underline">
                    {{ 'security.login.forgot_password'|trans }}
                </a>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="w-full rounded-md bg-blue-600 px-4 py-2 font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                {{ 'security.login.submit'|trans }}
            </button>
        </form>

        {% if google_oauth_enabled is defined and google_oauth_enabled %}
            <div class="relative">
                <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
                <div class="relative flex justify-center text-xs text-gray-400"><span class="bg-white px-2">{{ 'security.login.or'|trans }}</span></div>
            </div>
            <a href="{{ path('connect_google_start') }}"
               class="flex w-full items-center justify-center gap-3 rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50"
               data-turbo="false"
               data-testid="login-google-button">
                <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                {{ 'security.login.google'|trans }}
            </a>
        {% endif %}

        {% if entra_oauth_enabled is defined and entra_oauth_enabled %}
            <div class="relative">
                <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
                <div class="relative flex justify-center text-xs text-gray-400"><span class="bg-white px-2">{{ 'security.login.or'|trans }}</span></div>
            </div>
            <a href="{{ path('connect_entra_start') }}"
               class="flex w-full items-center justify-center gap-3 rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50"
               data-turbo="false"
               data-testid="login-entra-button">
                <svg class="h-5 w-5" viewBox="0 0 21 21" aria-hidden="true">
                    <rect x="1" y="1" width="9" height="9" fill="#F35325"/>
                    <rect x="11" y="1" width="9" height="9" fill="#81BC06"/>
                    <rect x="1" y="11" width="9" height="9" fill="#05A6F0"/>
                    <rect x="11" y="11" width="9" height="9" fill="#FFBA08"/>
                </svg>
                {{ 'security.login.entra'|trans }}
            </a>
        {% endif %}

        {% if ldap_enabled is defined and ldap_enabled %}
            <div class="relative">
                <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
                <div class="relative flex justify-center text-xs text-gray-400"><span class="bg-white px-2">{{ 'security.login.or'|trans }}</span></div>
            </div>
            <div class="rounded-md border border-blue-100 bg-blue-50 px-4 py-3 text-sm text-blue-800"
                 data-testid="login-ldap-notice">
                <svg class="mr-1.5 inline h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21 12 3l9.75 18H2.25Zm9.75-13.5v6m0 3h.008v.008H12V16.5Z"/>
                </svg>
                {{ 'security.login.ldap_hint'|trans }}
            </div>
        {% endif %}
        <p class="pt-2 text-center text-xs text-gray-400">
            Powered by <a href="https://github.com/markus-michalski/leaveflow"
                          target="_blank" rel="noopener noreferrer"
                          class="hover:text-gray-600 hover:underline">LeaveFlow</a>
        </p>
    </div>
</div>
{% endblock %}
