{% extends 'base.html.twig' %}

{% block title %}{{ 'error.403.title'|trans }} · {{ 'app.name'|trans }}{% endblock %}

{% block app_header %}{% endblock %}

{% block body %}
<div class="mx-auto max-w-2xl px-6 py-16 text-center">
    <svg class="mx-auto h-16 w-16 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
    </svg>
    <p class="mt-4 text-6xl font-bold text-gray-300">403</p>
    <h1 class="mt-4 text-2xl font-semibold text-gray-900">{{ 'error.403.heading'|trans }}</h1>
    <p class="mt-3 text-gray-600">{{ 'error.403.message'|trans }}</p>

    <div class="mt-8 flex items-center justify-center gap-3">
        <a href="{{ path('app_dashboard') }}"
           class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
            {{ 'error.generic.back_home'|trans }}
        </a>
    </div>
</div>
{% endblock %}
